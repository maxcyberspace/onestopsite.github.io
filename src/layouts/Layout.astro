---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  isEditor?: boolean;
}

const { 
  title = "88x31 Button Editor - Ultimate Neocities & Geocities Maker", 
  description = "Create, edit, and animate classic web 1.0 buttons with the ultimate 88x31 button editor. Perfect for Neocities templates, Geocities websites, indie web design, custom blinkies, and vintage GIFs.",
  isEditor = false 
} = Astro.props;

// Current path for active navigation styling
const currentPath = Astro.url.pathname;
const cleanPath = currentPath.endsWith('/') && currentPath.length > 1 ? currentPath.slice(0, -1) : currentPath;
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="88x31 button editor, neocities, neocities templates, neocities blinkies, indie web, indie web design, geocities, geocities website, geocities gifs, 88x31 button maker, retro buttons, pixel art badge, web 1.0 badge, animated gif button, blinkie maker, geocities buttons" />
    <meta name="author" content="OneStopSite" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.png" />
    <meta property="og:url" content={Astro.url.href} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    
    <!-- Google Fonts for Retro Pixel Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Silkscreen:wght@400;700&family=VT323&family=Pixelify+Sans:wght@400..700&family=Share+Tech+Mono&family=Geist+Mono:wght@100..900&display=swap" rel="stylesheet">
  </head>
  <body class="bg-black text-neutral-100 font-sans selection:bg-neutral-800 selection:text-white antialiased flex flex-col min-h-screen">
    
    <!-- Header (Skipped or customized in full Editor screen for layout optimization) -->
    {!isEditor && (
      <header class="sticky top-0 z-50 w-full border-b border-neutral-900 bg-black/80 backdrop-blur-md">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="flex h-16 items-center justify-between">
            <div class="flex items-center gap-8">
              <a href="/" class="flex items-center gap-2.5 transition-opacity hover:opacity-90">
                <div class="flex h-7 w-7 items-center justify-center rounded border border-neutral-800 bg-neutral-950 font-mono text-xs font-black text-white shadow-inner select-none" style="image-rendering: pixelated;">
                  <span class="text-xs text-neutral-400 font-sans font-bold">88</span>
                </div>
                <span class="text-sm font-bold tracking-tight text-white font-sans">
                  OneStopSite<span class="text-neutral-500 font-normal font-mono text-[10px] ml-1.5 border border-neutral-800 px-1 py-0.5 rounded">v1.0</span>
                </span>
              </a>
              <nav class="hidden md:flex items-center gap-3.5 lg:gap-5 xl:gap-6 text-xs lg:text-sm">
                <a 
                  href="/editor" 
                  class={`transition-colors hover:text-white ${cleanPath === '/editor' ? 'text-white font-medium' : 'text-neutral-400'}`}
                >
                  Editor
                </a>
                <a 
                  href="/templates" 
                  class={`transition-colors hover:text-white ${cleanPath === '/templates' ? 'text-white font-medium' : 'text-neutral-400'}`}
                >
                  Templates
                </a>
                <a 
                  href="/gallery" 
                  class={`transition-colors hover:text-white ${cleanPath === '/gallery' ? 'text-white font-medium' : 'text-neutral-400'}`}
                >
                  Gallery
                </a>
                <a 
                  href="/about" 
                  class={`transition-colors hover:text-white ${cleanPath === '/about' ? 'text-white font-medium' : 'text-neutral-400'}`}
                >
                  88x31 History
                </a>
                <a 
                  href="/about-us" 
                  class={`transition-colors hover:text-white ${cleanPath === '/about-us' ? 'text-white font-medium' : 'text-neutral-400'}`}
                >
                  About Us
                </a>
                <a 
                  href="/contact" 
                  class={`transition-colors hover:text-white ${cleanPath === '/contact' ? 'text-white font-medium' : 'text-neutral-400'}`}
                >
                  Contact Us
                </a>
                <a 
                  href="/privacy" 
                  class={`transition-colors hover:text-white ${cleanPath === '/privacy' ? 'text-white font-medium' : 'text-neutral-400'}`}
                >
                  Privacy Policy
                </a>
                <a 
                  href="/terms" 
                  class={`transition-colors hover:text-white ${cleanPath === '/terms' ? 'text-white font-medium' : 'text-neutral-400'}`}
                >
                  Terms &amp; Conditions
                </a>
              </nav>
            </div>
            
            <div class="flex items-center gap-4">
              <a 
                href="/editor" 
                class="hidden sm:inline-flex items-center justify-center rounded-md bg-white px-3 py-1.5 text-xs font-semibold text-black transition-colors hover:bg-neutral-200"
              >
                Launch Maker
              </a>
            </div>
          </div>
        </div>
      </header>
    )}

    <!-- Main Content Container -->
    <main class={`flex-grow ${isEditor ? '' : 'mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8 w-full'}`}>
      <slot />
    </main>

    <!-- Footer -->
    {!isEditor && (
      <footer class="mt-auto border-t border-neutral-900 bg-black py-8 text-neutral-500 text-xs">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
            <div class="flex items-center gap-3">
              <span class="font-bold text-neutral-300 font-sans text-xs">OneStopSite</span>
              <span class="text-neutral-800">|</span>
              <span>The Premier 88x31 Vintage Badge Builder</span>
            </div>
            
            <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-neutral-500">
              <a href="/editor" class="hover:text-neutral-300 transition-colors">Editor</a>
              <a href="/templates" class="hover:text-neutral-300 transition-colors">Templates</a>
              <a href="/gallery" class="hover:text-neutral-300 transition-colors">Gallery</a>
              <a href="/about" class="hover:text-neutral-300 transition-colors">History</a>
              <a href="/about-us" class="hover:text-neutral-300 transition-colors">About Us</a>
              <a href="/contact" class="hover:text-neutral-300 transition-colors">Contact Us</a>
              <a href="/privacy" class="hover:text-neutral-300 transition-colors">Privacy Policy</a>
              <a href="/terms" class="hover:text-neutral-300 transition-colors">Terms &amp; Conditions</a>
            </div>
          </div>
          
          <div class="mt-8 pt-8 border-t border-neutral-900 flex flex-col sm:flex-row items-center justify-between gap-4">
            <p>&copy; {new Date().getFullYear()} OneStopSite. All rights reserved.</p>
            <div class="flex items-center gap-2 text-neutral-400">
              <span class="inline-block h-2 w-2 rounded-full bg-emerald-500 animate-pulse"></span>
              <span class="font-mono text-[10px] uppercase tracking-wider">All Systems Operational</span>
            </div>
          </div>
        </div>
      </footer>
    )}
    
  </body>
</html>
