<!-- Client Side Scripting Bundled by Astro/Vite -->
<script>
  import { GIFEncoder, quantize, applyPalette } from 'gifenc';

  // 1. Types & Core State
  interface Layer {
    id: string;
    name: string;
    type: 'background' | 'text' | 'image' | 'shape' | 'overlay';
    visible: boolean;
    opacity: number; // 0-100
    blendMode: string;
    
    // Bounds
    x?: number;
    y?: number;
    width?: number;
    height?: number;
    rotation?: number;

    // Background specific
    bgType?: 'solid' | 'gradient' | 'image';
    color?: string;
    gradColor1?: string;
    gradColor2?: string;
    gradAngle?: number;
    imageSrc?: string; // Base64 DataURL
    size?: 'stretch' | 'tile';

    // Text specific
    text?: string;
    fontFamily?: string;
    fontSize?: number;
    align?: 'left' | 'center' | 'right';
    bold?: boolean;
    italic?: boolean;
    underline?: boolean;
    letterSpacing?: number;
    lineHeight?: number;
    strokeColor?: string;
    strokeWidth?: number;
    shadowColor?: string;
    shadowBlur?: number;
    shadowX?: number;
    shadowY?: number;
    glowEnabled?: boolean;
    glowColor?: string;
    glowSize?: number;

    // Image specific
    pixelated?: boolean;
    aspectLock?: boolean;
    cropEnabled?: boolean;
    cropLeft?: number;
    cropRight?: number;
    cropTop?: number;
    cropBottom?: number;
    filterGrayscale?: number;
    filterSepia?: number;
    filterInvert?: number;
    filterBlur?: number;
    filterContrast?: number;
    filterBrightness?: number;
    filterHueRotate?: number;

    // Shape specific
    shapeType?: 'rect' | 'roundrect' | 'circle' | 'line' | 'polygon' | 'star';
    fillColor?: string;
    fillEnabled?: boolean;
    borderColor?: string;
    borderWidth?: number;
    borderRadius?: number;
    polygonSides?: number;
    starPoints?: number;
    starInnerRatio?: number;

    // Overlay specific
    overlayType?: 'scanlines' | 'noise' | 'bevel' | 'gloss';
  }

  interface Frame {
    id: string;
    delay: number; // in ms
    overrides: Record<string, Partial<Layer>>;
  }

  // Preloaded image elements cache to render base64 quickly
  const imageElementCache: Record<string, HTMLImageElement> = {};

  // Default Preset Objects
  const PRESETS: Record<string, { layers: Layer[], frames: Frame[] }> = {
    win95: {
