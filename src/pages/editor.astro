---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="88x31 Button Editor & Badge Builder - OneStopSite Studio"
  description="Design pixel-perfect Neocities templates badges, Geocities website buttons, custom blinkies, and indie web design icons in the ultimate 88x31 button editor."
  isEditor={true}
>
  <div class="h-screen flex flex-col overflow-hidden bg-black text-neutral-200 select-none">
    <!-- Top Bar -->
    <header class="flex h-12 items-center justify-between border-b border-neutral-900 bg-neutral-950 px-4 flex-shrink-0 z-20">
      <div class="flex items-center gap-4">
        <a href="/" class="flex items-center gap-2 transition-opacity hover:opacity-80">
          <div class="flex h-5 w-5 items-center justify-center rounded border border-neutral-800 bg-black font-mono text-[9px] font-black text-white">88</div>
          <span class="text-xs font-bold tracking-tight text-white">OneStopSite</span>
        </a>
        <div class="h-4 w-px bg-neutral-900"></div>
        <div class="flex items-center gap-2">
          <input 
            type="text" 
            id="project-name" 
            value="Untitled Button" 
            class="bg-transparent border-b border-transparent hover:border-neutral-800 focus:border-white focus:outline-hidden text-xs font-medium text-white px-1 py-0.5 w-32 font-mono transition-colors"
          />
        </div>
      </div>

      <!-- Center History Actions -->
      <div class="flex items-center gap-1">
        <button 
          id="btn-undo" 
          title="Undo (Ctrl+Z)"
          data-tooltip="Undo last action"
          class="p-1.5 rounded hover:bg-neutral-900 text-neutral-400 hover:text-white transition-colors cursor-pointer"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12.066 11.2a1 1 0 000 1.6l5.334 4A1 1 0 0019 16V8a1 1 0 00-1.6-.8l-5.334 4z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.066 11.2a1 1 0 000 1.6l5.334 4A1 1 0 0011 16V8a1 1 0 00-1.6-.8l-5.334 4z" />
          </svg>
        </button>
        <button 
          id="btn-redo" 
          title="Redo (Ctrl+Y)"
          data-tooltip="Redo action"
          class="p-1.5 rounded hover:bg-neutral-900 text-neutral-400 hover:text-white transition-colors cursor-pointer"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.934 12.8a1 1 0 000-1.6l-5.334-4A1 1 0 005 8v8a1 1 0 001.6.8l5.334-4z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.934 12.8a1 1 0 000-1.6l-5.334-4A1 1 0 0013 8v8a1 1 0 001.6.8l5.334-4z" />
          </svg>
        </button>
      </div>

      <!-- Right Export & Share Actions -->
      <div class="flex items-center gap-2">
        <select 
          id="select-preset" 
          data-tooltip="Select a retro template preset to load"
          class="bg-neutral-900 hover:bg-neutral-850 border border-neutral-800 text-[11px] rounded px-2.5 py-1 text-neutral-300 outline-hidden font-medium cursor-pointer"
        >
          <option value="">-- Load Preset --</option>
          <option value="win95">Classic Windows 95</option>
          <option value="cyberpunk">Cyberpunk Neon</option>
          <option value="construction">Under Construction</option>
          <option value="starry">Pixel Starry Night</option>
          <option value="minimalist">Pure Notepad</option>
          <option value="glass">Vercel Glossy</option>
        </select>

        <div class="relative">
          <button 
            id="btn-export-dropdown" 
            data-tooltip="Export image or JSON project"
            class="flex items-center gap-1.5 rounded bg-white hover:bg-neutral-200 px-3 py-1 text-xs font-semibold text-black transition-colors cursor-pointer"
          >
            Export
            <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          
          <!-- Export Options Dropdown Menu -->
          <div 
            id="export-menu" 
            class="hidden absolute right-0 mt-1.5 w-44 rounded-md border border-neutral-900 bg-neutral-950 p-1 shadow-2xl z-50 text-[11px]"
          >
            <div class="px-2 py-1 text-[9px] uppercase tracking-wider text-neutral-600 font-mono font-bold">Static formats</div>
            <button data-format="png1x" class="export-opt w-full text-left rounded px-2 py-1.5 hover:bg-neutral-900 text-neutral-200 cursor-pointer">Export PNG (1x - 88x31)</button>
            <button data-format="png2x" class="export-opt w-full text-left rounded px-2 py-1.5 hover:bg-neutral-900 text-neutral-200 cursor-pointer">Export PNG (2x - 176x62)</button>
            <button data-format="png4x" class="export-opt w-full text-left rounded px-2 py-1.5 hover:bg-neutral-900 text-neutral-200 cursor-pointer">Export PNG (4x - 352x124)</button>
            
            <div class="h-px bg-neutral-900 my-1"></div>
            
            <div class="px-2 py-1 text-[9px] uppercase tracking-wider text-neutral-600 font-mono font-bold">Animated formats</div>
            <button id="export-gif-btn" class="w-full text-left rounded px-2 py-1.5 hover:bg-neutral-900 text-neutral-200 cursor-pointer">Export GIF (1x - 88x31)</button>
            <button id="export-gif-btn-large" class="w-full text-left rounded px-2 py-1.5 hover:bg-neutral-900 text-neutral-200 cursor-pointer">Export GIF (4x - 352x124)</button>
            
            <div class="h-px bg-neutral-900 my-1"></div>
            
            <div class="px-2 py-1 text-[9px] uppercase tracking-wider text-neutral-600 font-mono font-bold">Project File</div>
            <button id="btn-export-json" class="w-full text-left rounded px-2 py-1.5 hover:bg-neutral-900 text-neutral-200 cursor-pointer">Download project .json</button>
            <button id="btn-import-json-trigger" class="w-full text-left rounded px-2 py-1.5 hover:bg-neutral-900 text-neutral-200 cursor-pointer">Upload project .json</button>
            <input type="file" id="input-import-json" accept=".json" class="hidden" />
          </div>
        </div>
      </div>
    </header>

    <!-- Main Workspace Frame -->
    <div class="flex-grow flex overflow-hidden relative">
      
      <!-- Left Panel: Layers & Preset items -->
      <aside class="w-64 border-r border-neutral-900 bg-neutral-950 flex flex-col flex-shrink-0 z-10">
        <!-- Tabs Header -->
        <div class="h-9 border-b border-neutral-900 flex text-[10px] font-mono uppercase font-bold text-neutral-500 select-none">
          <button id="tab-btn-layers" data-tooltip="Manage editor layers stack" class="flex-1 hover:text-white border-b-2 border-b-emerald-500 text-white bg-black/30 transition-colors cursor-pointer">Layers</button>
          <button id="tab-btn-assets" data-tooltip="Browse and add retro pixel icons" class="flex-1 hover:text-white border-b-2 border-b-transparent transition-colors cursor-pointer">Assets</button>
        </div>

        <!-- Layers Section -->
        <div id="tab-content-layers" class="flex flex-col flex-grow overflow-hidden">
          <!-- Section: Layer adding controls -->
          <div class="p-3 border-b border-neutral-900 flex items-center justify-between">
            <span class="text-[10px] font-mono uppercase tracking-wider text-neutral-500 font-bold">Layers</span>
            <div class="relative">
              <button 
                id="btn-add-layer-dropdown" 
                data-tooltip="Add a new text, image, shape, or overlay layer"
                class="flex items-center gap-1 rounded border border-neutral-800 bg-black hover:bg-neutral-900 px-2.5 py-1 text-[10px] font-bold text-neutral-300 cursor-pointer"
              >
                + Add
              </button>
              
              <div 
                id="add-layer-menu" 
                class="hidden absolute right-0 mt-1 w-36 rounded border border-neutral-900 bg-neutral-950 p-1 shadow-xl z-50 text-[11px]"
              >
                <button data-type="text" class="add-layer-opt w-full text-left rounded px-2 py-1.5 hover:bg-neutral-900 text-neutral-200 cursor-pointer">Text Layer</button>
                <button data-type="image" class="add-layer-opt w-full text-left rounded px-2 py-1.5 hover:bg-neutral-900 text-neutral-200 cursor-pointer">Image Layer</button>
                <button data-type="shape" class="add-layer-opt w-full text-left rounded px-2 py-1.5 hover:bg-neutral-900 text-neutral-200 cursor-pointer">Shape Layer</button>
                <button data-type="overlay" class="add-layer-opt w-full text-left rounded px-2 py-1.5 hover:bg-neutral-900 text-neutral-200 cursor-pointer">Filter Overlay</button>
              </div>
            </div>
          </div>

          <!-- Layers List -->
          <div id="layers-list" class="flex-grow overflow-y-auto p-2 space-y-1">
            <!-- Populated by client side JS -->
          </div>
        </div>

        <!-- Assets Section -->
        <div id="tab-content-assets" class="hidden flex flex-col flex-grow overflow-hidden p-3 space-y-3">
          <div class="flex items-center justify-between">
            <span class="text-[10px] font-mono uppercase tracking-wider text-neutral-500 font-bold">Built-in Assets</span>
          </div>
          
          <div class="flex-grow overflow-y-auto pr-1">
            <div class="grid grid-cols-2 gap-2" id="assets-grid">
              <!-- Populated by JS -->
            </div>
          </div>
        </div>

        <!-- Shortcuts Help -->
        <div class="p-3 border-t border-neutral-900 text-[10px] text-neutral-500 font-mono leading-relaxed space-y-1 flex-shrink-0">
          <div class="font-bold text-neutral-400">Shortcuts:</div>
          <div>Drag layer to re-position</div>
          <div>Arrows: Nudge 1px</div>
          <div>Del / Backspace: Remove</div>
          <div>Ctrl+Z / Ctrl+Y: Undo/Redo</div>
        </div>
      </aside>

      <!-- Center Workspace (Canvas Viewport + Timeline Editor) -->
      <section class="flex-grow flex flex-col bg-[#0a0a0a] relative overflow-hidden">
        
        <!-- Canvas Viewport -->
        <div class="flex-grow flex items-center justify-center p-8 relative overflow-auto" id="viewport-container">
          
          <!-- Zoom indicator absolute widget -->
          <div class="absolute top-4 right-4 flex items-center gap-1.5 rounded border border-neutral-900 bg-neutral-950 px-2 py-1 text-[10px] text-neutral-400 font-mono z-10">
            <span>Zoom:</span>
            <select 
              id="select-zoom" 
              data-tooltip="Workspace zoom scale percentage"
              class="bg-neutral-900 hover:bg-neutral-850 border border-neutral-800 text-[10px] rounded px-1.5 py-0.5 text-neutral-300 outline-hidden font-medium cursor-pointer"
            >
              <option value="200" class="bg-neutral-950 text-neutral-200">200%</option>
              <option value="400" class="bg-neutral-950 text-neutral-200">400%</option>
              <option value="600" selected class="bg-neutral-950 text-neutral-200">600%</option>
              <option value="800" class="bg-neutral-950 text-neutral-200">800%</option>
              <option value="1200" class="bg-neutral-950 text-neutral-200">1200%</option>
            </select>
          </div>

          <!-- Grid Line Toggles -->
          <div class="absolute top-4 left-4 flex items-center gap-2 z-10">
            <button 
              id="btn-toggle-grid" 
              data-tooltip="Toggle layout alignment pixel grid lines"
              class="flex items-center gap-1 rounded border border-neutral-800 bg-neutral-950 hover:bg-neutral-900 px-2 py-1 text-[10px] text-neutral-400 font-mono cursor-pointer"
            >
              <span class="inline-block w-2 h-2 rounded-full bg-emerald-500" id="grid-status-dot"></span>
              Grid lines
            </button>
          </div>

          <!-- Interactive Editor Canvas Assembly -->
          <div class="relative shadow-2xl select-none" id="canvas-workspace-wrapper">
            <!-- Transparent check pattern backing -->
            <div class="absolute inset-0 bg-neutral-900" style="background-image: linear-gradient(45deg, #181818 25%, transparent 25%), linear-gradient(-45deg, #181818 25%, transparent 25%), linear-gradient(45deg, transparent 75%, #181818 75%), linear-gradient(-45deg, transparent 75%, #181818 75%); background-size: 10px 10px; background-position: 0 0, 0 5px, 5px -5px, -5px 0;"></div>
            
            <!-- Core Canvas element where button rendering happens -->
            <canvas 
              id="editor-canvas" 
              width="88" 
              height="31" 
              class="relative z-10 block cursor-default"
              style="image-rendering: pixelated; width: 528px; height: 186px;"
            ></canvas>

            <!-- Selection Overlay: Figma-like drag and scaling boxes -->
            <div 
              id="canvas-selection-box" 
              class="absolute z-20 pointer-events-none hidden border border-white mix-blend-difference"
              style="left: 0; top: 0; width: 0; height: 0; transform-origin: center;"
            >
              <!-- Corner Handles -->
              <div data-handle="tl" class="selection-handle absolute pointer-events-auto w-1.5 h-1.5 bg-white border border-black -left-1 -top-1 cursor-nwse-resize"></div>
              <div data-handle="tr" class="selection-handle absolute pointer-events-auto w-1.5 h-1.5 bg-white border border-black -right-1 -top-1 cursor-nesw-resize"></div>
              <div data-handle="bl" class="selection-handle absolute pointer-events-auto w-1.5 h-1.5 bg-white border border-black -left-1 -bottom-1 cursor-nesw-resize"></div>
              <div data-handle="br" class="selection-handle absolute pointer-events-auto w-1.5 h-1.5 bg-white border border-black -right-1 -bottom-1 cursor-nwse-resize"></div>
              <!-- Rotation Handle -->
              <div id="rotate-handle" class="selection-handle absolute pointer-events-auto w-2 h-2 bg-white border border-black rounded-full cursor-alias -translate-x-1/2" style="left: 50%; top: -16px;"></div>
              <div class="absolute w-px bg-white -translate-x-1/2 pointer-events-none" style="left: 50%; top: -16px; height: 16px;"></div>
            </div>
          </div>
        </div>

        <!-- Animation Timeline Panel (Bottom) -->
        <div class="h-44 border-t border-neutral-900 bg-neutral-950 flex flex-col flex-shrink-0 z-10 font-mono">
          <!-- Timeline Controls -->
          <div class="h-9 border-b border-neutral-900 px-3 flex items-center justify-between flex-shrink-0">
            <div class="flex items-center gap-3">
              <span class="text-[9px] uppercase tracking-wider text-neutral-500 font-bold">Animation Timeline</span>
              <div class="h-3 w-px bg-neutral-900"></div>
              <div class="flex items-center gap-1.5">
                <button 
                  id="btn-play-pause" 
                  data-tooltip="Play / pause the timeline animation preview"
                  class="rounded bg-neutral-900 border border-neutral-800 hover:bg-neutral-850 hover:text-white px-2 py-0.5 text-[10px] text-neutral-300 font-bold transition-colors cursor-pointer"
                >
                  PLAY
                </button>
              </div>
            </div>

            <div class="flex items-center gap-3 text-[10px] text-neutral-400">
              <div class="flex items-center gap-1">
                <span>Speed:</span>
                <select 
                  id="timeline-speed" 
                  data-tooltip="Playback speed multiplier scaling delay"
                  class="bg-neutral-900 hover:bg-neutral-850 border border-neutral-800 text-[10px] rounded px-1.5 py-0.5 text-neutral-300 outline-hidden font-medium cursor-pointer"
                >
                  <option value="0.5" class="bg-neutral-950 text-neutral-200">0.5x</option>
                  <option value="1" selected class="bg-neutral-950 text-neutral-200">1.0x</option>
                  <option value="1.5" class="bg-neutral-950 text-neutral-200">1.5x</option>
                  <option value="2" class="bg-neutral-950 text-neutral-200">2.0x</option>
                </select>
              </div>
              <button 
                id="btn-add-frame" 
                data-tooltip="Create a new timeline keyframe frame"
                class="rounded border border-neutral-800 bg-black hover:bg-neutral-900 px-2 py-0.5 text-[10px] text-neutral-300 font-bold cursor-pointer"
              >
                + Add Frame
              </button>
            </div>
          </div>

          <!-- Frames Slider -->
          <div id="frames-strip" class="flex-grow flex items-center gap-3 overflow-x-auto p-3">
            <!-- Populated by client-side JS -->
          </div>
        </div>
      </section>

      <!-- Right Panel: Context-aware Properties Inspector -->
      <aside class="w-72 border-l border-neutral-900 bg-neutral-950 flex flex-col flex-shrink-0 overflow-y-auto p-4 z-10">
        
        <!-- Inspector Title -->
        <div class="border-b border-neutral-900 pb-3 mb-4 flex items-center justify-between">
          <span class="text-[10px] font-mono uppercase tracking-wider text-neutral-500 font-bold">Inspector</span>
          <div class="flex gap-2">
            <button id="btn-duplicate-active-layer" data-tooltip="Duplicate active selected layer" class="text-[9px] text-neutral-600 hover:text-emerald-400 transition-colors uppercase font-mono font-bold hidden cursor-pointer">
              Duplicate
            </button>
            <button id="btn-delete-active-layer" data-tooltip="Delete active selected layer" class="text-[9px] text-neutral-600 hover:text-rose-400 transition-colors uppercase font-mono font-bold hidden cursor-pointer">
              Delete
            </button>
          </div>
        </div>

        <!-- Global Inspector Settings (Visible if no layer selected) -->
        <div id="inspector-global" class="space-y-5">
          <p class="text-xs text-neutral-500 italic">Select a layer to customize its vector properties, or tweak template presets from the options above.</p>
          
          <div class="space-y-2 border-t border-neutral-900 pt-4">
            <span class="text-[10px] font-mono uppercase text-neutral-500 font-bold">Canvas Settings</span>
            <div class="grid grid-cols-2 gap-2 text-xs">
              <div class="border border-neutral-900 bg-neutral-950/40 p-2 rounded">
                <div class="text-[9px] text-neutral-600 font-bold uppercase font-mono">Width</div>
                <div class="font-bold text-white font-mono mt-1">88 px</div>
              </div>
              <div class="border border-neutral-900 bg-neutral-950/40 p-2 rounded">
                <div class="text-[9px] text-neutral-600 font-bold uppercase font-mono">Height</div>
                <div class="font-bold text-white font-mono mt-1">31 px</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Layer Settings Inspector (Active when a layer is selected) -->
        <div id="inspector-layer" class="hidden space-y-5">
          
          <!-- Shared Layer Properties -->
          <div class="space-y-3">
            <label class="block">
              <span class="text-[9px] font-mono uppercase tracking-wider text-neutral-500 block mb-1.5 font-bold">Layer Name</span>
              <input type="text" id="layer-name" class="w-full bg-black border border-neutral-900 rounded px-2 py-1.5 text-xs text-white focus:border-neutral-700 outline-hidden font-mono" />
            </label>

            <!-- Numeric sizing controls -->
            <div class="grid grid-cols-4 gap-1.5">
              <label class="block">
                <span class="text-[8px] font-mono uppercase text-neutral-500 block mb-1">X</span>
                <input type="number" id="layer-x" class="w-full bg-black border border-neutral-900 rounded px-1.5 py-1 text-xs text-white text-center font-mono focus:border-neutral-700 outline-hidden" />
              </label>
              <label class="block">
                <span class="text-[8px] font-mono uppercase text-neutral-500 block mb-1">Y</span>
                <input type="number" id="layer-y" class="w-full bg-black border border-neutral-900 rounded px-1.5 py-1 text-xs text-white text-center font-mono focus:border-neutral-700 outline-hidden" />
              </label>
              <label class="block">
                <span class="text-[8px] font-mono uppercase text-neutral-500 block mb-1">W</span>
                <input type="number" id="layer-w" class="w-full bg-black border border-neutral-900 rounded px-1.5 py-1 text-xs text-white text-center font-mono focus:border-neutral-700 outline-hidden" />
              </label>
              <label class="block">
                <span class="text-[8px] font-mono uppercase text-neutral-500 block mb-1">H</span>
                <input type="number" id="layer-h" class="w-full bg-black border border-neutral-900 rounded px-1.5 py-1 text-xs text-white text-center font-mono focus:border-neutral-700 outline-hidden" />
              </label>
            </div>

            <!-- Opacity Slider -->
            <div class="space-y-1">
              <div class="flex items-center justify-between">
                <span class="text-[8px] font-mono uppercase text-neutral-500 block">Opacity</span>
                <span id="opacity-value" class="text-[8px] font-mono text-neutral-400">100%</span>
              </div>
              <input type="range" id="layer-opacity" min="0" max="100" class="w-full h-1 bg-neutral-900 rounded-lg appearance-none cursor-pointer outline-hidden" />
            </div>

            <!-- Blending & Rotation -->
            <div class="grid grid-cols-2 gap-2">
              <label class="block">
                <span class="text-[8px] font-mono uppercase text-neutral-500 block mb-1">Rotate (°)</span>
                <input type="number" id="layer-rotation" min="0" max="360" class="w-full bg-black border border-neutral-900 rounded px-1.5 py-1 text-xs text-white text-center font-mono focus:border-neutral-700 outline-hidden" />
              </label>
              <label class="block">
                <span class="text-[8px] font-mono uppercase text-neutral-500 block mb-1">Blending</span>
                <select id="layer-blend" class="w-full bg-black border border-neutral-900 rounded px-1.5 py-1 text-[10px] text-white focus:border-neutral-700 outline-hidden cursor-pointer">
                  <option value="source-over">Normal</option>
                  <option value="multiply">Multiply</option>
                  <option value="screen">Screen</option>
                  <option value="overlay">Overlay</option>
                  <option value="darken">Darken</option>
                  <option value="lighten">Lighten</option>
                </select>
              </label>
            </div>
          </div>

          <!-- Type specific properties stack -->
          <div class="h-px bg-neutral-900 my-4"></div>

          <!-- 1. Background Properties Panel -->
          <div id="pane-bg" class="hidden space-y-4">
            <span class="text-[9px] font-mono uppercase tracking-wider text-neutral-500 block font-bold">Background Options</span>
            
            <label class="block">
              <span class="text-[8px] font-mono uppercase text-neutral-500 block mb-1">Fill Type</span>
              <select id="bg-fill-type" class="w-full bg-black border border-neutral-900 rounded px-2 py-1.5 text-xs text-white focus:border-neutral-700 outline-hidden cursor-pointer">
                <option value="solid">Solid Color</option>
                <option value="gradient">Gradient Fill</option>
                <option value="image">Uploaded Image</option>
              </select>
            </label>

            <!-- Solid Background Option -->
            <div id="bg-solid-opt" class="space-y-2">
              <label class="block">
                <span class="text-[8px] font-mono uppercase text-neutral-500 block mb-1">Background Color</span>
                <div class="flex gap-2">
                  <input type="color" id="bg-color-picker" class="bg-black border border-neutral-900 rounded h-8 w-12 p-0.5 cursor-pointer" />
                  <input type="text" id="bg-color-hex" class="flex-grow bg-black border border-neutral-900 rounded px-2 py-1.5 text-xs text-white font-mono focus:border-neutral-700 outline-hidden" />
                </div>
              </label>
            </div>

            <!-- Gradient Background Option -->
            <div id="bg-gradient-opt" class="hidden space-y-3">
              <div class="grid grid-cols-2 gap-2">
                <label class="block">
                  <span class="text-[8px] font-mono uppercase text-neutral-500 block mb-1">Color 1</span>
                  <input type="color" id="bg-grad-1" class="w-full bg-black border border-neutral-900 rounded h-8 p-0.5 cursor-pointer" />
                </label>
                <label class="block">
                  <span class="text-[8px] font-mono uppercase text-neutral-500 block mb-1">Color 2</span>
                  <input type="color" id="bg-grad-2" class="w-full bg-black border border-neutral-900 rounded h-8 p-0.5 cursor-pointer" />
                </label>
              </div>
              <label class="block">
                <span class="text-[8px] font-mono uppercase text-neutral-500 block mb-1">Angle (Degrees)</span>
                <input type="number" id="bg-grad-angle" value="90" min="0" max="360" class="w-full bg-black border border-neutral-900 rounded px-2 py-1.5 text-xs text-white font-mono focus:border-neutral-700 outline-hidden" />
              </label>
            </div>

            <!-- Image Background Option -->
            <div id="bg-image-opt" class="hidden space-y-3">
              <label class="block">
                <span class="text-[8px] font-mono uppercase text-neutral-500 block mb-1">Upload File</span>
                <input type="file" id="bg-image-file" accept="image/png, image/jpeg, image/gif" class="w-full bg-black border border-neutral-900 rounded text-neutral-400 p-1 text-[10px] focus:outline-hidden" />
              </label>
              <label class="block">
