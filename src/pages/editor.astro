  // Get or initialize frame overrides for a layer ID
  function getOrCreateOverride(layerId: string): Partial<Layer> {
    const frame = project.frames[project.activeFrameIndex];
    if (!frame.overrides) frame.overrides = {};
    if (!frame.overrides[layerId]) frame.overrides[layerId] = {};
    return frame.overrides[layerId];
  }

  // Helper to measure text boundaries accurately
  function getTextLayerBounds(eff: Partial<Layer>) {
    const fs = eff.fontSize || 8;
    const lh = (eff.lineHeight || 1.2) * fs;
    const lines = (eff.text || '').split('\n');
    
    ctx.save();
    ctx.font = `${eff.italic ? 'italic' : ''} ${eff.bold ? 'bold' : ''} ${fs}px "${eff.fontFamily || 'Geist Mono'}"`;
    if (eff.letterSpacing) {
      ctx.letterSpacing = `${eff.letterSpacing}px`;
    } else {
      ctx.letterSpacing = '0px';
    }
    
    let maxLineWidth = 0;
    lines.forEach(lineText => {
      const w = ctx.measureText(lineText).width;
      if (w > maxLineWidth) maxLineWidth = w;
    });
    ctx.restore();
    
    const h = lines.length * lh;
    const w = maxLineWidth;
    
    let x = eff.x || 0;
    const y = eff.y || 0;
    
    if (eff.align === 'center') {
      x = x - w / 2;
    } else if (eff.align === 'right') {
      x = x - w;
    }
    
    return { x, y, w, h };
  }

  // Draw background frame updates quickly without sidebars updates (reduces lag)
  function renderCanvas() {
    const scale = project.zoom / 100;
    canvas.width = Math.round(88 * scale);
    canvas.height = Math.round(31 * scale);
    canvas.style.width = `${88 * scale}px`;
    canvas.style.height = `${31 * scale}px`;

    // Clear CSS background image since we draw grid directly on canvas
    canvas.style.backgroundImage = 'none';

    ctx.save();
    ctx.scale(scale, scale);
    ctx.imageSmoothingEnabled = false;
    drawCanvasFrame(ctx, project.activeFrameIndex);
    ctx.restore();

    // Draw grid overlay on the main canvas if enabled
    if (project.gridVisible) {
      ctx.save();
      ctx.globalCompositeOperation = 'difference';
      ctx.strokeStyle = '#333333'; // subtle difference grid lines
      ctx.lineWidth = 1;
      
      // Vertical grid lines
      for (let x = 1; x < 88; x++) {
        const xPos = Math.round(x * scale);
        ctx.beginPath();
        ctx.moveTo(xPos - 0.5, 0);
        ctx.lineTo(xPos - 0.5, canvas.height);
        ctx.stroke();
      }
      
      // Horizontal grid lines
      for (let y = 1; y < 31; y++) {
        const yPos = Math.round(y * scale);
        ctx.beginPath();
        ctx.moveTo(0, yPos - 0.5);
        ctx.lineTo(canvas.width, yPos - 0.5);
        ctx.stroke();
      }
      ctx.restore();
    }

    updateSelectionOverlay();
  }

  // Helper to find layer at mouse coordinate
  function findLayerAt(mouseX: number, mouseY: number): Layer | null {
    for (let i = project.layers.length - 1; i >= 0; i--) {
      const layer = project.layers[i];
      if (!layer.visible || layer.type === 'background' || layer.type === 'overlay') continue;
      
      const eff = getLayerEffective(layer, project.activeFrameIndex);
      const lx = eff.x || 0;
      const ly = eff.y || 0;
      
      if (layer.type === 'image' || layer.type === 'shape') {
        const lw = eff.width || 0;
        const lh = eff.height || 0;
        if (mouseX >= lx && mouseX <= lx + lw && mouseY >= ly && mouseY <= ly + lh) {
          return layer;
        }
      } else if (layer.type === 'text' && eff.text) {
        const bounds = getTextLayerBounds(eff);
        if (mouseX >= bounds.x && mouseX <= bounds.x + bounds.w && mouseY >= bounds.y && mouseY <= bounds.y + bounds.h) {
          return layer;
        }
      }
    }
    return null;
  }

  // Setup client side listeners for dragging selection boxes, dropping images, and pasting
  function setupDraggingListeners() {
    canvas.onmousedown = (e) => {
      if (e.button !== 0) return; // Only process left click for dragging
      const rect = canvas.getBoundingClientRect();
      const scale = project.zoom / 100;
      const mouseX = (e.clientX - rect.left) / scale;
      const mouseY = (e.clientY - rect.top) / scale;
      
      const clickedLayer = findLayerAt(mouseX, mouseY);
      
      if (clickedLayer) {
        if (e.shiftKey || e.ctrlKey || e.metaKey) {
          if (project.selectedLayerIds.includes(clickedLayer.id)) {
            // Toggle off selection
            project.selectedLayerIds = project.selectedLayerIds.filter(id => id !== clickedLayer.id);
            project.activeLayerId = project.selectedLayerIds.length > 0 
              ? project.selectedLayerIds[project.selectedLayerIds.length - 1] 
              : null;
            renderAll();
            // Don't drag if we just deselected it
            return;
          } else {
            // Toggle on selection
            project.selectedLayerIds.push(clickedLayer.id);
            project.activeLayerId = clickedLayer.id;
          }
        } else {
          if (!project.selectedLayerIds.includes(clickedLayer.id)) {
            project.selectedLayerIds = [clickedLayer.id];
            project.activeLayerId = clickedLayer.id;
          }
        }
        
        renderAll();
        
        dragMode = 'move';
        dragStartMouseX = mouseX;
        dragStartMouseY = mouseY;
        
        draggedLayersStartPositions = project.layers
          .filter(l => project.selectedLayerIds.includes(l.id))
          .map(l => {
            const eff = getLayerEffective(l, project.activeFrameIndex);
            return {
              id: l.id,
              x: eff.x || 0,
              y: eff.y || 0
            };
          });
      } else {
        if (!e.shiftKey && !e.ctrlKey && !e.metaKey) {
          project.selectedLayerIds = [];
          project.activeLayerId = null;
          renderAll();
        }
      }
    };

    // Handles rotate handle clicks
    const rotateHandle = document.getElementById('rotate-handle');
    if (rotateHandle) {
      rotateHandle.onmousedown = (e) => {
        e.stopPropagation();
        e.preventDefault();
        
        const active = project.layers.find(l => l.id === project.activeLayerId);
        if (!active) return;
        
        const eff = getLayerEffective(active, project.activeFrameIndex);
        const rect = canvas.getBoundingClientRect();
        const scale = project.zoom / 100;
        
        dragMode = 'rotate';
        
        const lx = eff.x || 0;
        const ly = eff.y || 0;
        const lw = eff.width || 0;
        const lh = eff.height || 0;
        
        let cx = lx + lw / 2;
        let cy = ly + lh / 2;
        if (active.type === 'text') {
          const bounds = getTextLayerBounds(eff);
          cx = bounds.x + bounds.w / 2;
          cy = bounds.y + bounds.h / 2;
        }
        
        dragStartRotateCenter = { x: cx, y: cy };
        dragStartLayerRotation = eff.rotation || 0;
        
        const mouseX = (e.clientX - rect.left) / scale;
        const mouseY = (e.clientY - rect.top) / scale;
        dragStartMouseAngle = Math.atan2(mouseY - cy, mouseX - cx);
      };
    }

    // Handles handles clicks
    const handles = document.querySelectorAll('.selection-handle:not(#rotate-handle)');
    handles.forEach(handle => {
      (handle as HTMLDivElement).onmousedown = (e) => {
        e.stopPropagation();
        e.preventDefault();
        
        const active = project.layers.find(l => l.id === project.activeLayerId);
        if (!active) return;
        
        const eff = getLayerEffective(active, project.activeFrameIndex);
        const rect = canvas.getBoundingClientRect();
        const scale = project.zoom / 100;
        
        dragMode = 'resize';
        resizeHandle = (handle as HTMLDivElement).dataset.handle || '';
        dragStartMouseX = (e.clientX - rect.left) / scale;
        dragStartMouseY = (e.clientY - rect.top) / scale;
        
        dragStartLayerX = eff.x || 0;
        dragStartLayerY = eff.y || 0;
        dragStartLayerW = eff.width || 0;
        dragStartLayerH = eff.height || 0;
      };
    });

    window.onmousemove = (e) => {
      if (!dragMode) return;
      
      const active = project.layers.find(l => l.id === project.activeLayerId);
      if (!active) return;
      
      const rect = canvas.getBoundingClientRect();
      const scale = project.zoom / 100;
      const mouseX = (e.clientX - rect.left) / scale;
      const mouseY = (e.clientY - rect.top) / scale;
      
      const dx = mouseX - dragStartMouseX;
      const dy = mouseY - dragStartMouseY;
      
      if (dragMode === 'move') {
        draggedLayersStartPositions.forEach(startPos => {
          const l = project.layers.find(layer => layer.id === startPos.id);
          if (l) {
            const override = getOrCreateOverride(l.id);
            override.x = Math.round(startPos.x + dx);
            override.y = Math.round(startPos.y + dy);
          }
        });
      } else if (dragMode === 'resize') {
        const override = getOrCreateOverride(active.id);
        
        let newX = dragStartLayerX;
        let newY = dragStartLayerY;
        let newW = dragStartLayerW;
        let newH = dragStartLayerH;
        
        if (resizeHandle.includes('r')) newW = Math.max(1, Math.round(dragStartLayerW + dx));
        if (resizeHandle.includes('b')) newH = Math.max(1, Math.round(dragStartLayerH + dy));
        
        if (resizeHandle.includes('l')) {
          const possibleW = Math.round(dragStartLayerW - dx);
          if (possibleW > 0) {
            newW = possibleW;
            newX = Math.round(dragStartLayerX + dx);
          }
        }
        if (resizeHandle.includes('t')) {
          const possibleH = Math.round(dragStartLayerH - dy);
          if (possibleH > 0) {
            newH = possibleH;
            newY = Math.round(dragStartLayerY + dy);
          }
        }
        
        override.x = newX;
        override.y = newY;
        override.width = newW;
        override.height = newH;
      } else if (dragMode === 'rotate') {
        const override = getOrCreateOverride(active.id);
        const currentAngle = Math.atan2(mouseY - dragStartRotateCenter.y, mouseX - dragStartRotateCenter.x);
        const angleDiff = currentAngle - dragStartMouseAngle;
        let newRotation = dragStartLayerRotation + Math.round((angleDiff * 180) / Math.PI);
        newRotation = (newRotation % 360 + 360) % 360;
        if (e.shiftKey) {
          newRotation = Math.round(newRotation / 15) * 15;
        }
        override.rotation = newRotation;
      }
      
      renderCanvas();
      updateSelectionOverlay();
      saveToLocalStorage();
    };

    window.onmouseup = () => {
      if (dragMode) {
        dragMode = null;
        pushState();
      }
    };

    // Drag and Drop files handler
    canvasWorkspaceWrapper.addEventListener('dragover', (e) => {
      e.preventDefault();
      canvasWorkspaceWrapper.classList.add('ring-2', 'ring-emerald-500');
    });

    canvasWorkspaceWrapper.addEventListener('dragleave', () => {
      canvasWorkspaceWrapper.classList.remove('ring-2', 'ring-emerald-500');
    });

    canvasWorkspaceWrapper.addEventListener('drop', (e) => {
      e.preventDefault();
      canvasWorkspaceWrapper.classList.remove('ring-2', 'ring-emerald-500');
      if (e.dataTransfer?.files && e.dataTransfer.files.length > 0) {
        const file = e.dataTransfer.files[0];
        if (file.type.startsWith('image/')) {
          const reader = new FileReader();
          reader.onload = (evt) => {
            const base64 = evt.target?.result as string;
            if (base64) {
              preloadImage(base64, (img) => {
                const id = `layer-${Date.now()}`;
                const newLayer: Layer = {
                  id,
                  name: 'Dropped Image',
                  type: 'image',
                  visible: true,
                  opacity: 100,
                  blendMode: 'source-over',
                  x: 10,
                  y: 5,
                  width: Math.min(88, img.width),
                  height: Math.round(img.height * (Math.min(88, img.width) / img.width)),
                  imageSrc: base64,
                  pixelated: true,
                  aspectLock: true
                };
                project.layers.push(newLayer);
                project.activeLayerId = id;
                project.selectedLayerIds = [id];
                pushState();
                renderAll();
              });
            }
          };
          reader.readAsDataURL(file);
        }
      }
    });

    // Paste from clipboard handler
    window.addEventListener('paste', (e) => {
      // Avoid pasting when typing in form controls
      if (['INPUT', 'TEXTAREA', 'SELECT'].includes((e.target as HTMLElement).tagName)) return;
      const items = e.clipboardData?.items;
      if (!items) return;
      for (let i = 0; i < items.length; i++) {
        if (items[i].type.indexOf('image') !== -1) {
          const file = items[i].getAsFile();
          if (!file) continue;
          const reader = new FileReader();
          reader.onload = (evt) => {
            const base64 = evt.target?.result as string;
            if (base64) {
              preloadImage(base64, (img) => {
                const id = `layer-${Date.now()}`;
                const newLayer: Layer = {
                  id,
                  name: 'Pasted Image',
                  type: 'image',
                  visible: true,
                  opacity: 100,
                  blendMode: 'source-over',
                  x: 10,
                  y: 5,
                  width: Math.min(88, img.width),
                  height: Math.round(img.height * (Math.min(88, img.width) / img.width)),
                  imageSrc: base64,
                  pixelated: true,
                  aspectLock: true
                };
                project.layers.push(newLayer);
                project.activeLayerId = id;
                project.selectedLayerIds = [id];
                pushState();
                renderAll();
              });
            }
          };
          reader.readAsDataURL(file);
          break;
        }
      }
    });
  }

  // Arrow Key nudging logic + hotkeys
  function setupGlobalHotkeys() {
    window.addEventListener('keydown', (e) => {
      // Don't intercept if user is typing in form controls
      if (['INPUT', 'TEXTAREA', 'SELECT'].includes((e.target as HTMLElement).tagName)) return;
      
      const active = project.layers.find(l => l.id === project.activeLayerId);
      
      // Delete active layers
      if ((e.key === 'Delete' || e.key === 'Backspace') && (active || (project.selectedLayerIds && project.selectedLayerIds.length > 0))) {
        deleteActiveLayer();
        return;
      }

      // Duplicate active layer shortcut
      if (e.ctrlKey && e.key.toLowerCase() === 'd') {
        e.preventDefault();
        duplicateActiveLayer();
        return;
      }
      
      // Arrow nudges
      if (['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight'].includes(e.key) && active) {
        e.preventDefault();
        const amt = e.shiftKey ? 5 : 1;
        const override = getOrCreateOverride(active.id);
        const eff = getLayerEffective(active, project.activeFrameIndex);
        
        if (e.key === 'ArrowUp') override.y = (eff.y || 0) - amt;
        if (e.key === 'ArrowDown') override.y = (eff.y || 0) + amt;
        if (e.key === 'ArrowLeft') override.x = (eff.x || 0) - amt;
        if (e.key === 'ArrowRight') override.x = (eff.x || 0) + amt;
        
        pushState();
        renderAll();
        return;
      }
      
      // Undo/Redo shortcuts
      if (e.ctrlKey && e.key.toLowerCase() === 'z') {
        e.preventDefault();
        undo();
      }
      if (e.ctrlKey && e.key.toLowerCase() === 'y') {
        e.preventDefault();
        redo();
      }
    });
  }

  function deleteActiveLayer() {
    const idsToDelete = project.selectedLayerIds && project.selectedLayerIds.length > 0 
      ? [...project.selectedLayerIds] 
      : (project.activeLayerId ? [project.activeLayerId] : []);
    
    if (idsToDelete.length === 0) return;
    
    idsToDelete.forEach(id => {
      const index = project.layers.findIndex(l => l.id === id);
      if (index !== -1) {
        project.layers.splice(index, 1);
      }
      
      // Clean up overrides in all frames
      project.frames.forEach(frame => {
        if (frame.overrides && frame.overrides[id]) {
          delete frame.overrides[id];
        }
      });
    });
    
    project.selectedLayerIds = [];
    project.activeLayerId = null;
    pushState();
    renderAll();
  }

  function duplicateActiveLayer() {
    const idsToDuplicate = project.selectedLayerIds && project.selectedLayerIds.length > 0 
      ? [...project.selectedLayerIds] 
      : (project.activeLayerId ? [project.activeLayerId] : []);
      
    if (idsToDuplicate.length === 0) return;
    
    const newSelectedIds: string[] = [];
    let lastNewId: string | null = null;
    
    // Sort duplicated layers to maintain relative ordering
    const sortedIds = [...idsToDuplicate].sort((a, b) => {
      const idxA = project.layers.findIndex(l => l.id === a);
      const idxB = project.layers.findIndex(l => l.id === b);
      return idxA - idxB;
    });
    
    sortedIds.forEach(id => {
      const active = project.layers.find(l => l.id === id);
      if (!active) return;
      
      const newId = `layer-${Date.now()}-${Math.random().toString(36).substr(2, 9)}`;
      const copy = JSON.parse(JSON.stringify(active));
      copy.id = newId;
      copy.name = `${active.name} Copy`;
      if (typeof copy.x === 'number') copy.x += 5;
      if (typeof copy.y === 'number') copy.y += 5;
      
      const idx = project.layers.findIndex(l => l.id === id);
      if (idx !== -1) {
        project.layers.splice(idx + 1, 0, copy);
      }
      
      // Duplicate overrides across all keyframes
      project.frames.forEach(frame => {
        if (frame.overrides && frame.overrides[id]) {
          const frameOverride = JSON.parse(JSON.stringify(frame.overrides[id]));
          if (typeof frameOverride.x === 'number') frameOverride.x += 5;
          if (typeof frameOverride.y === 'number') frameOverride.y += 5;
          frame.overrides[newId] = frameOverride;
        }
      });
      
      newSelectedIds.push(newId);
      lastNewId = newId;
    });
    
    if (newSelectedIds.length > 0) {
      project.selectedLayerIds = newSelectedIds;
      project.activeLayerId = lastNewId;
      pushState();
      renderAll();
    }
  }

  // Setup playback intervals
  function startPlayback() {
    project.isPlaying = true;
    playPauseBtn.textContent = 'PAUSE';
    playPauseBtn.classList.remove('bg-neutral-900');
    playPauseBtn.classList.add('bg-emerald-600', 'text-white');
    
    let speed = parseFloat(speedSelect.value) || 1;
    
    function run() {
      if (!project.isPlaying) return;
      const currentFrame = project.frames[project.activeFrameIndex];
      const nextIdx = (project.activeFrameIndex + 1) % project.frames.length;
      
      isPlayingTimer = setTimeout(() => {
        project.activeFrameIndex = nextIdx;
        renderAll();
        run();
      }, (currentFrame.delay || 200) / speed);
    }
    
    run();
  }

  function pausePlayback() {
    project.isPlaying = false;
    if (isPlayingTimer) clearTimeout(isPlayingTimer);
    playPauseBtn.textContent = 'PLAY';
    playPauseBtn.classList.remove('bg-emerald-600', 'text-white');
    playPauseBtn.classList.add('bg-neutral-900');
  }

  // Image Upload handler
  function handleImageUpload(e: Event, type: 'bg' | 'layer') {
    const input = e.target as HTMLInputElement;
    if (!input.files || input.files.length === 0) return;
    
    const file = input.files[0];
    const reader = new FileReader();
    reader.onload = (evt) => {
      const base64 = evt.target?.result as string;
      if (!base64) return;
      
      preloadImage(base64, (img) => {
        const active = project.layers.find(l => l.id === project.activeLayerId);
        if (active) {
          if (type === 'bg' && active.type === 'background') {
            active.imageSrc = base64;
          } else if (type === 'layer' && active.type === 'image') {
            active.imageSrc = base64;
            // Set size properties matching preloaded image
            const override = getOrCreateOverride(active.id);
            // Default fits to canvas
            override.width = Math.min(88, img.width);
            override.height = Math.round(img.height * (Math.min(88, img.width) / img.width));
          }
          pushState();
          renderAll();
        }
      });
    };
    reader.readAsDataURL(file);
  }

  // High fidelity exports actions
  function exportPNG(scale = 1) {
    const tempCanvas = document.createElement('canvas');
    tempCanvas.width = 88 * scale;
    tempCanvas.height = 31 * scale;
    const tempCtx = tempCanvas.getContext('2d')!;
    
    // Scale canvas context to get high resolution crisp pixels
    tempCtx.scale(scale, scale);
    drawCanvasFrame(tempCtx, project.activeFrameIndex);
    
    const link = document.createElement('a');
    link.download = `${project.name.replace(/\s+/g, '-').toLowerCase()}-${scale}x.png`;
    link.href = tempCanvas.toDataURL('image/png');
    link.click();
  }

  function exportGIF(scale = 1) {
    // Show loading text on export button
    const oldText = exportBtn.textContent;
    exportBtn.textContent = 'Exporting...';
    exportBtn.disabled = true;

    // Use a short delay to allow UI updates
    setTimeout(() => {
      try {
        const encoder = new GIFEncoder();
        
        // Render each frame at the requested size
        project.frames.forEach((frame, idx) => {
          const tempCanvas = document.createElement('canvas');
          tempCanvas.width = 88 * scale;
          tempCanvas.height = 31 * scale;
          const tempCtx = tempCanvas.getContext('2d')!;
          
          tempCtx.scale(scale, scale);
          drawCanvasFrame(tempCtx, idx);
          
          // Quantize and write frame
          const imgData = tempCtx.getImageData(0, 0, 88 * scale, 31 * scale);
          const palette = quantize(imgData.data, 256);
          const index = applyPalette(imgData.data, palette);
          
          encoder.writeFrame(index, 88 * scale, 31 * scale, {
            palette: palette,
            delay: frame.delay
          });
        });
        
        encoder.finish();
        const buffer = encoder.bytes();
        const blob = new Blob([buffer], { type: 'image/gif' });
        const url = URL.createObjectURL(blob);
        
        const link = document.createElement('a');
        link.download = `${project.name.replace(/\s+/g, '-').toLowerCase()}.gif`;
        link.href = url;
        link.click();
        
        URL.revokeObjectURL(url);
      } catch (err) {
        console.error(err);
        alert('GIF Encoding Failed. Try reducing scaling size or layering amount.');
      } finally {
        exportBtn.textContent = 'Export';
        exportBtn.disabled = false;
        exportMenu.classList.add('hidden');
      }
    }, 100);
  }

  // Setup event listeners for new layers additions
  function addLayer(type: 'text' | 'image' | 'shape' | 'overlay') {
    const id = `layer-${Date.now()}`;
    let name = '';
    let newLayer: Layer;

    if (type === 'text') {
      name = 'Text Layer';
      newLayer = {
        id, name, type,
        visible: true, opacity: 100, blendMode: 'source-over',
        x: 10, y: 11, text: 'TEXT', fontFamily: 'Geist Mono', fontSize: 8,
        color: '#ffffff', strokeColor: '#000000', strokeWidth: 0,
        align: 'left', bold: false, italic: false
      };
    } else if (type === 'image') {
      name = 'Image Layer';
      newLayer = {
        id, name, type,
        visible: true, opacity: 100, blendMode: 'source-over',
        x: 10, y: 5, width: 20, height: 20, pixelated: true, aspectLock: true
      };
    } else if (type === 'shape') {
      name = 'Shape Layer';
      newLayer = {
        id, name, type,
        visible: true, opacity: 100, blendMode: 'source-over',
        x: 10, y: 10, width: 30, height: 15, shapeType: 'rect',
        fillEnabled: true, fillColor: '#ffffff', borderColor: '#000000', borderWidth: 0
      };
    } else if (type === 'overlay') {
      name = 'Filter Layer';
      newLayer = {
        id, name, type,
        visible: true, opacity: 50, blendMode: 'source-over',
        overlayType: 'scanlines'
      };
    }

    project.layers.push(newLayer!);
    project.activeLayerId = id;
    pushState();
    renderAll();
  }

