  const exportMenu = document.getElementById('export-menu') as HTMLDivElement;

  // Save/Restore State to History
  function pushState() {
    const serialized = JSON.stringify({
      name: project.name,
      layers: project.layers,
      frames: project.frames,
      activeLayerId: project.activeLayerId,
      selectedLayerIds: project.selectedLayerIds || [],
      activeFrameIndex: project.activeFrameIndex
    });
    
    // Avoid identical consecutive saves
    if (undoStack.length > 0 && undoStack[undoStack.length - 1] === serialized) return;
    
    undoStack.push(serialized);
    if (undoStack.length > 50) undoStack.shift(); // Limit history stack depth
    redoStack = []; // Clear redo stack on new operation
    updateHistoryButtons();
    saveToLocalStorage();
  }

  function undo() {
    if (undoStack.length <= 1) return; // Keep at least the initial state
    const current = undoStack.pop()!;
    redoStack.push(current);
    
    const previous = undoStack[undoStack.length - 1];
    const restored = JSON.parse(previous);
    restoreFromObject(restored);
  }

  function redo() {
    if (redoStack.length === 0) return;
    const next = redoStack.pop()!;
    undoStack.push(next);
    
    const restored = JSON.parse(next);
    restoreFromObject(restored);
  }

  function restoreFromObject(restored: any) {
    project.name = restored.name;
    project.layers = restored.layers;
    project.frames = restored.frames;
    project.activeLayerId = restored.activeLayerId;
    project.selectedLayerIds = restored.selectedLayerIds || (restored.activeLayerId ? [restored.activeLayerId] : []);
    project.activeFrameIndex = restored.activeFrameIndex;
    
    document.title = `${project.name} | OneStopSite Button Studio`;
    (document.getElementById('project-name') as HTMLInputElement).value = project.name;
    
    preloadProjectImages(() => {
      renderAll();
    });
    updateHistoryButtons();
  }

  function updateHistoryButtons() {
    const undoBtn = document.getElementById('btn-undo') as HTMLButtonElement;
    const redoBtn = document.getElementById('btn-redo') as HTMLButtonElement;
    
    if (undoStack.length <= 1) {
      undoBtn.classList.add('opacity-30', 'pointer-events-none');
    } else {
      undoBtn.classList.remove('opacity-30', 'pointer-events-none');
    }
    
    if (redoStack.length === 0) {
      redoBtn.classList.add('opacity-30', 'pointer-events-none');
    } else {
      redoBtn.classList.remove('opacity-30', 'pointer-events-none');
    }
  }

  function saveToLocalStorage() {
    const serialized = JSON.stringify({
      name: project.name,
      layers: project.layers,
      frames: project.frames,
      selectedLayerIds: project.selectedLayerIds || []
    });
    localStorage.setItem('onestopsite-active-project', serialized);
  }

  // Preloads images in project so canvas doesn't draw blank boxes
  function preloadProjectImages(callback: () => void) {
    let pending = 0;
    project.layers.forEach(layer => {
      if ((layer.type === 'background' && layer.bgType === 'image' && layer.imageSrc) || 
          (layer.type === 'image' && layer.imageSrc)) {
        const src = layer.imageSrc;
        if (!imageElementCache[src]) {
          pending++;
          const img = new Image();
          img.src = src;
          img.onload = () => {
            imageElementCache[src] = img;
            pending--;
            if (pending === 0) callback();
          };
          img.onerror = () => {
            pending--;
            if (pending === 0) callback();
          };
        }
      }
    });
    if (pending === 0) callback();
  }

  // Preloads a single base64 image and caches it
  function preloadImage(src: string, callback: (img: HTMLImageElement) => void) {
    if (imageElementCache[src]) {
      callback(imageElementCache[src]);
      return;
    }
    const img = new Image();
    img.src = src;
    img.onload = () => {
      imageElementCache[src] = img;
      callback(img);
    };
  }

  // Load preset templates into project
  function loadPreset(presetId: string) {
    const preset = PRESETS[presetId];
    if (!preset) return;
    
    project.name = `${PRESETS[presetId] ? presetId.toUpperCase() : 'Untitled'} Button`;
    project.layers = JSON.parse(JSON.stringify(preset.layers));
    project.frames = JSON.parse(JSON.stringify(preset.frames));
    project.activeLayerId = project.layers[project.layers.length - 1]?.id || null;
    project.selectedLayerIds = project.activeLayerId ? [project.activeLayerId] : [];
    project.activeFrameIndex = 0;
    
    const nameInput = document.getElementById('project-name') as HTMLInputElement;
    if (nameInput) nameInput.value = project.name;
    
    // Clear stacks
    undoStack = [];
    redoStack = [];
    pushState();
    
    preloadProjectImages(() => {
      renderAll();
    });
  }

  // Resolve dynamic layer properties based on timeline frame overrides
  function getLayerEffective(layer: Layer, frameIndex: number): Layer {
    const frame = project.frames[frameIndex];
    if (!frame || !frame.overrides || !frame.overrides[layer.id]) return layer;
    return {
      ...layer,
      ...frame.overrides[layer.id]
    };
  }

  // Clear Canvas and Draw Layers Sequence
  function drawCanvasFrame(ctx2d: CanvasRenderingContext2D, frameIdx: number) {
    ctx2d.clearRect(0, 0, 88, 31);
    
    project.layers.forEach(layer => {
      const eff = getLayerEffective(layer, frameIdx);
      if (!eff.visible) return;
      
      ctx2d.save();
      ctx2d.globalAlpha = eff.opacity / 100;
      ctx2d.globalCompositeOperation = eff.blendMode as any;

      // Handle Rotation
      const rotation = eff.rotation || 0;
      if (rotation !== 0) {
        let cx = 0;
        let cy = 0;
        if (eff.type === 'image' || eff.type === 'shape') {
          cx = (eff.x || 0) + (eff.width || 0) / 2;
          cy = (eff.y || 0) + (eff.height || 0) / 2;
        } else if (eff.type === 'text') {
          cx = eff.x || 0;
          cy = eff.y || 0;
        }
        ctx2d.translate(cx, cy);
        ctx2d.rotate((rotation * Math.PI) / 180);
        ctx2d.translate(-cx, -cy);
      }

      if (eff.type === 'background') {
        if (eff.bgType === 'solid' && eff.color) {
          ctx2d.fillStyle = eff.color;
          ctx2d.fillRect(0, 0, 88, 31);
        } else if (eff.bgType === 'gradient' && eff.gradColor1 && eff.gradColor2) {
          // Compute linear gradient from angle
          const angleRad = ((eff.gradAngle || 90) * Math.PI) / 180;
          const r = Math.sqrt(88*88 + 31*31) / 2;
          const cx = 44, cy = 15.5;
          const x0 = cx - Math.cos(angleRad) * r;
          const y0 = cy - Math.sin(angleRad) * r;
          const x1 = cx + Math.cos(angleRad) * r;
          const y1 = cy + Math.sin(angleRad) * r;
          
          const grad = ctx2d.createLinearGradient(x0, y0, x1, y1);
          grad.addColorStop(0, eff.gradColor1);
          grad.addColorStop(1, eff.gradColor2);
          ctx2d.fillStyle = grad;
          ctx2d.fillRect(0, 0, 88, 31);
        } else if (eff.bgType === 'image' && eff.imageSrc) {
          const img = imageElementCache[eff.imageSrc];
          if (img) {
            ctx2d.imageSmoothingEnabled = false;
            if (eff.size === 'tile') {
              const pattern = ctx2d.createPattern(img, 'repeat');
              if (pattern) {
                ctx2d.fillStyle = pattern;
                ctx2d.fillRect(0, 0, 88, 31);
              }
            } else {
              ctx2d.drawImage(img, 0, 0, 88, 31);
            }
          }
        }
      } else if (eff.type === 'image' && eff.imageSrc) {
        const img = imageElementCache[eff.imageSrc];
        if (img) {
          ctx2d.imageSmoothingEnabled = !eff.pixelated;
          
          // Save state for filter application
          ctx2d.save();
          let filterStr = '';
          if (eff.filterGrayscale) filterStr += ` grayscale(${eff.filterGrayscale}%)`;
          if (eff.filterSepia) filterStr += ` sepia(${eff.filterSepia}%)`;
          if (eff.filterInvert) filterStr += ` invert(${eff.filterInvert}%)`;
          if (eff.filterBlur) filterStr += ` blur(${eff.filterBlur}px)`;
          if (eff.filterContrast && eff.filterContrast !== 100) filterStr += ` contrast(${eff.filterContrast}%)`;
          if (eff.filterBrightness && eff.filterBrightness !== 100) filterStr += ` brightness(${eff.filterBrightness}%)`;
          if (eff.filterHueRotate) filterStr += ` hue-rotate(${eff.filterHueRotate}deg)`;
          
          if (filterStr.trim()) {
            ctx2d.filter = filterStr.trim();
          } else {
            ctx2d.filter = 'none';
          }

          if (eff.cropEnabled) {
            const cropL = eff.cropLeft || 0;
            const cropR = eff.cropRight || 0;
            const cropT = eff.cropTop || 0;
            const cropB = eff.cropBottom || 0;
            
            const sx = (cropL / 100) * img.width;
            const sy = (cropT / 100) * img.height;
            const sw = img.width - sx - (cropR / 100) * img.width;
            const sh = img.height - sy - (cropB / 100) * img.height;
            
            ctx2d.drawImage(img, sx, sy, Math.max(1, sw), Math.max(1, sh), eff.x || 0, eff.y || 0, eff.width || 0, eff.height || 0);
          } else {
            ctx2d.drawImage(img, eff.x || 0, eff.y || 0, eff.width || 0, eff.height || 0);
          }
          ctx2d.restore();
        }
      } else if (eff.type === 'shape') {
        const x = eff.x || 0;
        const y = eff.y || 0;
        const w = eff.width || 0;
        const h = eff.height || 0;
        
        ctx2d.beginPath();
        if (eff.shapeType === 'rect' || !eff.shapeType) {
          ctx2d.rect(x, y, w, h);
        } else if (eff.shapeType === 'roundrect') {
          const r = eff.borderRadius ?? 4;
          if (typeof ctx2d.roundRect === 'function') {
            ctx2d.roundRect(x, y, w, h, r);
          } else {
            ctx2d.rect(x, y, w, h);
          }
        } else if (eff.shapeType === 'circle') {
          ctx2d.ellipse(x + w / 2, y + h / 2, Math.abs(w / 2), Math.abs(h / 2), 0, 0, 2 * Math.PI);
        } else if (eff.shapeType === 'line') {
          ctx2d.moveTo(x, y);
          ctx2d.lineTo(x + w, y + h);
        } else if (eff.shapeType === 'polygon') {
          const sides = eff.polygonSides || 5;
          const cx = x + w / 2;
          const cy = y + h / 2;
          const rx = w / 2;
          const ry = h / 2;
          ctx2d.moveTo(cx + rx * Math.cos(-Math.PI / 2), cy + ry * Math.sin(-Math.PI / 2));
          for (let i = 1; i <= sides; i++) {
            const angle = (i * 2 * Math.PI) / sides - Math.PI / 2;
            ctx2d.lineTo(cx + rx * Math.cos(angle), cy + ry * Math.sin(angle));
          }
          ctx2d.closePath();
        } else if (eff.shapeType === 'star') {
          const points = eff.starPoints || 5;
          const cx = x + w / 2;
          const cy = y + h / 2;
          const rx = w / 2;
          const ry = h / 2;
          const innerRatio = eff.starInnerRatio || 0.4;
          for (let i = 0; i < 2 * points; i++) {
            const angle = (i * Math.PI) / points - Math.PI / 2;
            const rCurrX = (i % 2 === 0) ? rx : rx * innerRatio;
            const rCurrY = (i % 2 === 0) ? ry : ry * innerRatio;
            if (i === 0) {
              ctx2d.moveTo(cx + rCurrX * Math.cos(angle), cy + rCurrY * Math.sin(angle));
            } else {
              ctx2d.lineTo(cx + rCurrX * Math.cos(angle), cy + rCurrY * Math.sin(angle));
            }
          }
          ctx2d.closePath();
        }
        
        if (eff.fillEnabled && eff.shapeType !== 'line') {
          ctx2d.fillStyle = eff.fillColor || '#ffffff';
          ctx2d.fill();
        }
        
        if (eff.borderWidth && eff.borderWidth > 0) {
          ctx2d.strokeStyle = eff.borderColor || '#000000';
          ctx2d.lineWidth = eff.borderWidth;
          ctx2d.stroke();
        }
      } else if (eff.type === 'text' && eff.text) {
        const x = eff.x || 0;
        const y = eff.y || 0;
        
        // Setup font string
        ctx2d.font = `${eff.italic ? 'italic' : ''} ${eff.bold ? 'bold' : ''} ${eff.fontSize || 8}px "${eff.fontFamily || 'Geist Mono'}"`;
        ctx2d.textAlign = (eff.align || 'left') as any;
        ctx2d.textBaseline = 'top'; // Align baseline top for precise selection bounds
        
        if (eff.letterSpacing) {
          ctx2d.letterSpacing = `${eff.letterSpacing}px`;
        } else {
          ctx2d.letterSpacing = '0px';
        }

        const lines = eff.text.split('\n');
        const lh = (eff.lineHeight || 1.2) * (eff.fontSize || 8);

        const drawLines = (isGlowPass: boolean) => {
          lines.forEach((lineText, lineIndex) => {
            const currentY = y + lineIndex * lh;
            
            if (isGlowPass) {
              ctx2d.shadowColor = eff.glowColor || 'transparent';
              ctx2d.shadowBlur = eff.glowSize || 0;
              ctx2d.shadowOffsetX = 0;
              ctx2d.shadowOffsetY = 0;
            } else {
              if ((eff.shadowBlur && eff.shadowBlur > 0) || (eff.shadowX && eff.shadowX !== 0) || (eff.shadowY && eff.shadowY !== 0)) {
                ctx2d.shadowColor = eff.shadowColor || 'transparent';
                ctx2d.shadowBlur = eff.shadowBlur || 0;
                ctx2d.shadowOffsetX = eff.shadowX || 0;
                ctx2d.shadowOffsetY = eff.shadowY || 0;
              } else {
                ctx2d.shadowBlur = 0;
                ctx2d.shadowOffsetX = 0;
                ctx2d.shadowOffsetY = 0;
              }
            }

            // Stroke outline
            if (eff.strokeWidth && eff.strokeWidth > 0 && eff.strokeColor) {
              ctx2d.strokeStyle = eff.strokeColor;
              ctx2d.lineWidth = eff.strokeWidth;
              ctx2d.lineJoin = 'miter';
              ctx2d.miterLimit = 2;
              ctx2d.strokeText(lineText, x, currentY);
            }
            
            // Fill base text
            ctx2d.fillStyle = eff.color || '#ffffff';
            ctx2d.fillText(lineText, x, currentY);

            // Underline (not during glow pass)
            if (!isGlowPass && eff.underline) {
              ctx2d.save();
              ctx2d.shadowColor = 'transparent';
              ctx2d.shadowBlur = 0;
              ctx2d.shadowOffsetX = 0;
              ctx2d.shadowOffsetY = 0;
              
              const textWidth = ctx2d.measureText(lineText).width;
              let startX = x;
              if (eff.align === 'center') startX = x - textWidth / 2;
              else if (eff.align === 'right') startX = x - textWidth;
              
              ctx2d.strokeStyle = eff.color || '#ffffff';
              ctx2d.lineWidth = Math.max(1, Math.round((eff.fontSize || 8) / 10));
              ctx2d.beginPath();
              const underlineY = currentY + (eff.fontSize || 8) + Math.max(1, Math.round((eff.fontSize || 8) * 0.05));
              ctx2d.moveTo(startX, underlineY);
              ctx2d.lineTo(startX + textWidth, underlineY);
              ctx2d.stroke();
              ctx2d.restore();
            }
          });
        };

        // Double pass render: glow first, then drop shadows and fills
        if (eff.glowEnabled && eff.glowColor && (eff.glowSize || 0) > 0) {
          ctx2d.save();
          drawLines(true);
          ctx2d.restore();
        }
        
        drawLines(false);
      } else if (eff.type === 'overlay') {
        if (eff.overlayType === 'bevel') {
          ctx2d.lineWidth = 1;
          // White light highlights top/left
          ctx2d.strokeStyle = '#ffffff';
          ctx2d.beginPath(); ctx2d.moveTo(0, 30); ctx2d.lineTo(0, 0); ctx2d.lineTo(87, 0); ctx2d.stroke();
          // Inner gray shadows bottom/right
          ctx2d.strokeStyle = '#808080';
          ctx2d.beginPath(); ctx2d.moveTo(1, 29); ctx2d.lineTo(86, 29); ctx2d.lineTo(86, 1); ctx2d.stroke();
          // Outer black border bottom/right
          ctx2d.strokeStyle = '#000000';
          ctx2d.beginPath(); ctx2d.moveTo(0, 30); ctx2d.lineTo(87, 30); ctx2d.lineTo(87, 0); ctx2d.stroke();
        } else if (eff.overlayType === 'scanlines') {
          ctx2d.strokeStyle = '#ffffff';
          ctx2d.lineWidth = 0.5;
          for (let i = -31; i < 88; i += 3) {
            ctx2d.beginPath();
            ctx2d.moveTo(i, 0);
            ctx2d.lineTo(i + 31, 31);
            ctx2d.stroke();
          }
        } else if (eff.overlayType === 'gloss') {
          ctx2d.fillStyle = 'rgba(255, 255, 255, 0.15)';
          ctx2d.beginPath();
          ctx2d.moveTo(0, 0);
          ctx2d.lineTo(88, 0);
          ctx2d.lineTo(88, 12);
          ctx2d.bezierCurveTo(60, 16, 28, 16, 0, 12);
          ctx2d.closePath();
          ctx2d.fill();
        } else if (eff.overlayType === 'noise') {
          const imgData = ctx2d.getImageData(0, 0, 88, 31);
          const pix = imgData.data;
          for (let i = 0; i < pix.length; i += 4) {
            const grain = (Math.random() - 0.5) * 35;
            pix[i] = Math.min(255, Math.max(0, pix[i] + grain));
            pix[i+1] = Math.min(255, Math.max(0, pix[i+1] + grain));
            pix[i+2] = Math.min(255, Math.max(0, pix[i+2] + grain));
          }
          ctx2d.putImageData(imgData, 0, 0);
        }
      }
      
      ctx2d.restore();
    });
  }

  // Core Render loop: draws canvas, grid overlay, selection outlines, and inspector
  function renderAll() {
    // 1. Draw button canvas and selection handles (resized/scaled internally)
    renderCanvas();

    // 3. Render left panel layers stack
    renderLayersList();

    // 4. Render bottom timeline frames
    renderTimelineStrip();

    // 5. Update inspector inputs
    updateInspectorPanel();
  }

  // Update position of Figma selection bounding box on viewport
  function updateSelectionOverlay() {
    // Remove any existing multi-select dynamic borders
    const existing = document.querySelectorAll('.multi-select-border');
    existing.forEach(el => el.remove());

    const selectedLayers = project.layers.filter(l => 
      (project.selectedLayerIds || []).includes(l.id) && 
      l.type !== 'background' && 
      l.type !== 'overlay' && 
      l.visible
    );

    if (selectedLayers.length === 0) {
      canvasSelectionBox.classList.add('hidden');
      return;
    }

    const scale = project.zoom / 100;

    if (selectedLayers.length === 1) {
      // Single selection: show main box with handles
      const active = selectedLayers[0];
      const eff = getLayerEffective(active, project.activeFrameIndex);
      let x = eff.x || 0;
      let y = eff.y || 0;
      let w = eff.width || 0;
      let h = eff.height || 0;
      
      if (active.type === 'text') {
        const bounds = getTextLayerBounds(eff);
        x = bounds.x;
        y = bounds.y;
        w = bounds.w;
        h = bounds.h;
      }
      
      canvasSelectionBox.style.left = `${x * scale}px`;
      canvasSelectionBox.style.top = `${y * scale}px`;
      canvasSelectionBox.style.width = `${w * scale}px`;
      canvasSelectionBox.style.height = `${h * scale}px`;
      
      const rotation = eff.rotation || 0;
      canvasSelectionBox.style.transform = `rotate(${rotation}deg)`;
      canvasSelectionBox.style.transformOrigin = 'center';
      
      canvasSelectionBox.querySelectorAll('.selection-handle, #rotate-handle').forEach(el => {
        (el as HTMLElement).style.display = active.type === 'text' && el.id !== 'rotate-handle' ? 'none' : 'block';
      });
      canvasSelectionBox.classList.remove('hidden');
    } else {
      // Multi-selection: show a combined boundary box and dashed outlines for each layer
      let minX = Infinity, minY = Infinity;
      let maxX = -Infinity, maxY = -Infinity;
      
      selectedLayers.forEach(l => {
        const eff = getLayerEffective(l, project.activeFrameIndex);
        let lx = eff.x || 0;
        let ly = eff.y || 0;
        let lw = eff.width || 0;
        let lh = eff.height || 0;
        
        if (l.type === 'text') {
          const bounds = getTextLayerBounds(eff);
          lx = bounds.x;
          ly = bounds.y;
          lw = bounds.w;
          lh = bounds.h;
        }
        
        minX = Math.min(minX, lx);
        minY = Math.min(minY, ly);
        maxX = Math.max(maxX, lx + lw);
        maxY = Math.max(maxY, ly + lh);
        
        // Draw individual dashed outline div
        const d = document.createElement('div');
        d.className = 'multi-select-border absolute border border-dashed border-white/60 pointer-events-none z-20';
        d.style.left = `${lx * scale}px`;
        d.style.top = `${ly * scale}px`;
        d.style.width = `${lw * scale}px`;
        d.style.height = `${lh * scale}px`;
        if (eff.rotation) {
          d.style.transform = `rotate(${eff.rotation}deg)`;
          d.style.transformOrigin = 'center';
        }
        canvasWorkspaceWrapper.appendChild(d);
      });
      
      canvasSelectionBox.style.left = `${minX * scale}px`;
      canvasSelectionBox.style.top = `${minY * scale}px`;
      canvasSelectionBox.style.width = `${(maxX - minX) * scale}px`;
      canvasSelectionBox.style.height = `${(maxY - minY) * scale}px`;
      canvasSelectionBox.style.transform = 'none';
      
      canvasSelectionBox.querySelectorAll('.selection-handle, #rotate-handle').forEach(el => {
        (el as HTMLElement).style.display = 'none';
      });
      canvasSelectionBox.classList.remove('hidden');
    }
  }

  // Render left panel layers items list
  function renderLayersList() {
    layersList.innerHTML = '';
    
    // Display layers reverse (top layer drawn last, so shows at top of sidebar)
    [...project.layers].reverse().forEach(layer => {
      const isSelected = (project.selectedLayerIds || []).includes(layer.id);
      const isActive = layer.id === project.activeLayerId;
      
      const activeClass = isSelected 
        ? (isActive ? 'bg-neutral-800 border-neutral-700 text-white font-semibold' : 'bg-neutral-900 border-neutral-800 text-neutral-200')
        : 'border-transparent text-neutral-400 hover:bg-neutral-950';
      
      const item = document.createElement('div');
      item.className = `group flex items-center justify-between rounded border px-2.5 py-1.5 text-xs transition-colors cursor-pointer ${activeClass}`;
      item.onclick = (e) => {
        if (e.shiftKey || e.ctrlKey || e.metaKey) {
          if (project.selectedLayerIds.includes(layer.id)) {
            if (project.selectedLayerIds.length > 1) {
              project.selectedLayerIds = project.selectedLayerIds.filter(id => id !== layer.id);
              if (project.activeLayerId === layer.id) {
                project.activeLayerId = project.selectedLayerIds[project.selectedLayerIds.length - 1];
              }
            }
          } else {
            project.selectedLayerIds.push(layer.id);
            project.activeLayerId = layer.id;
          }
        } else {
          project.selectedLayerIds = [layer.id];
          project.activeLayerId = layer.id;
        }
        renderAll();
      };
      
      // Eye visibility toggle
      const eyeColor = layer.visible ? 'text-neutral-400 hover:text-white' : 'text-neutral-800 hover:text-neutral-500';
      const eyeIcon = layer.visible ? 
        `<svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg>` : 
        `<svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.542-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.542 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" /></svg>`;
        
      item.innerHTML = `
        <div class="flex items-center gap-2 font-mono truncate">
          <span class="text-[9px] px-1 rounded bg-neutral-900 border border-neutral-800 text-neutral-500 font-bold uppercase select-none">
            ${layer.type.slice(0, 2)}
          </span>
          <span class="truncate pr-1">${layer.name}</span>
        </div>
        
        <div class="flex items-center gap-2 opacity-50 group-hover:opacity-100 transition-opacity">
          <!-- Visibility button -->
          <button class="btn-toggle-vis p-0.5 rounded hover:bg-neutral-800 ${eyeColor}" title="Toggle Visibility">
            ${eyeIcon}
          </button>
          
          <!-- Re-ordering arrows -->
          <div class="flex flex-col gap-px">
            <button class="btn-move-up p-0.5 hover:text-white" title="Move Up">&and;</button>
            <button class="btn-move-down p-0.5 hover:text-white" title="Move Down">&or;</button>
          </div>
        </div>
      `;
      
      // Wire visibility toggle
      const visBtn = item.querySelector('.btn-toggle-vis') as HTMLButtonElement;
      visBtn.onclick = (e) => {
        e.stopPropagation();
        layer.visible = !layer.visible;
        pushState();
        renderAll();
      };
      
      // Wire move-up
      const upBtn = item.querySelector('.btn-move-up') as HTMLButtonElement;
      upBtn.onclick = (e) => {
        e.stopPropagation();
        const index = project.layers.findIndex(l => l.id === layer.id);
        if (index < project.layers.length - 1) {
          project.layers[index] = project.layers[index + 1];
          project.layers[index + 1] = layer;
          pushState();
          renderAll();
        }
      };
      
      // Wire move-down
      const downBtn = item.querySelector('.btn-move-down') as HTMLButtonElement;
      downBtn.onclick = (e) => {
        e.stopPropagation();
        const index = project.layers.findIndex(l => l.id === layer.id);
        if (index > 0) {
          project.layers[index] = project.layers[index - 1];
          project.layers[index - 1] = layer;
          pushState();
          renderAll();
        }
      };

      // Wire right-click context menu
      item.oncontextmenu = (e) => {
        e.preventDefault();
        e.stopPropagation();
        
        if (!project.selectedLayerIds.includes(layer.id)) {
          project.selectedLayerIds = [layer.id];
          project.activeLayerId = layer.id;
          renderAll();
        }
        
        showContextMenu(e.clientX, e.clientY);
      };
      
      layersList.appendChild(item);
    });
  }

  // Render bottom timeline strip
  function renderTimelineStrip() {
    framesStrip.innerHTML = '';
    
    project.frames.forEach((frame, idx) => {
      const activeClass = idx === project.activeFrameIndex ? 'border-white bg-neutral-900' : 'border-neutral-900 bg-neutral-950/40 hover:border-neutral-800';
      
      const thumb = document.createElement('div');
      thumb.className = `flex-shrink-0 flex flex-col items-center border rounded p-1.5 transition-all cursor-pointer ${activeClass}`;
      thumb.style.width = '120px';
      thumb.onclick = () => {
        project.activeFrameIndex = idx;
        renderAll();
      };
      
      // Render simulated canvas preview inside frame strip using dynamic miniature canvas
      const miniCanvas = document.createElement('canvas');
      miniCanvas.width = 88;
      miniCanvas.height = 31;
      miniCanvas.className = 'w-full h-[32px] border border-neutral-900 rounded bg-black';
      miniCanvas.style.imageRendering = 'pixelated';
      const mCtx = miniCanvas.getContext('2d')!;
      drawCanvasFrame(mCtx, idx);
      
      thumb.appendChild(miniCanvas);
      
      // Frame delay inputs
      const controlBar = document.createElement('div');
      controlBar.className = 'w-full flex items-center justify-between text-[9px] mt-1.5 font-bold';
      controlBar.innerHTML = `
        <div class="flex items-center gap-0.5">
          <span>#${idx+1}</span>
          <input 
            type="number" 
            value="${frame.delay}" 
            min="50" 
            max="2000" 
            step="50"
            class="w-10 bg-black border border-neutral-900 rounded text-center text-white focus:outline-hidden" 
          />
          <span>ms</span>
        </div>
        <div class="flex items-center gap-1">
          <button class="btn-dup-frame hover:text-white px-0.5" title="Duplicate Frame">&#10697;</button>
          <button class="btn-del-frame hover:text-rose-400 px-0.5" title="Delete Frame">&#10005;</button>
        </div>
      `;
      
      // Wire delay changes
      const delayInput = controlBar.querySelector('input') as HTMLInputElement;
      delayInput.onclick = (e) => e.stopPropagation();
      delayInput.onchange = (e) => {
        frame.delay = Math.max(50, parseInt(delayInput.value) || 100);
        pushState();
        renderAll();
      };
      
      // Wire duplicate frame
      const dupBtn = controlBar.querySelector('.btn-dup-frame') as HTMLButtonElement;
      dupBtn.onclick = (e) => {
        e.stopPropagation();
        const copy = JSON.parse(JSON.stringify(frame));
        copy.id = `frame-${Date.now()}`;
        project.frames.splice(idx + 1, 0, copy);
        project.activeFrameIndex = idx + 1;
        pushState();
        renderAll();
      };
      
      // Wire delete frame
      const delBtn = controlBar.querySelector('.btn-del-frame') as HTMLButtonElement;
      delBtn.onclick = (e) => {
        e.stopPropagation();
        if (project.frames.length <= 1) return; // Prevent deleting the last frame
        project.frames.splice(idx, 1);
        project.activeFrameIndex = Math.max(0, idx - 1);
        pushState();
        renderAll();
      };
      
      thumb.appendChild(controlBar);
      framesStrip.appendChild(thumb);
    });
  }

  // Update properties inputs inside Inspector panel
  function updateInspectorPanel() {
    const active = project.layers.find(l => l.id === project.activeLayerId);
    const deleteBtn = document.getElementById('btn-delete-active-layer') as HTMLButtonElement;
    const dupBtn = document.getElementById('btn-duplicate-active-layer') as HTMLButtonElement;
    
    if (!active) {
      inspectorGlobal.classList.remove('hidden');
      inspectorLayer.classList.add('hidden');
      deleteBtn.classList.add('hidden');
      dupBtn.classList.add('hidden');
      return;
    }
    
    inspectorGlobal.classList.add('hidden');
    inspectorLayer.classList.remove('hidden');
    deleteBtn.classList.remove('hidden');
    dupBtn.classList.remove('hidden');

    const eff = getLayerEffective(active, project.activeFrameIndex);

    // Update shared attributes
    (document.getElementById('layer-name') as HTMLInputElement).value = active.name;
    
    const opacitySlider = document.getElementById('layer-opacity') as HTMLInputElement;
    opacitySlider.value = active.opacity.toString();
    const opacityValSpan = document.getElementById('opacity-value') as HTMLSpanElement;
    if (opacityValSpan) opacityValSpan.textContent = `${active.opacity}%`;
    
    const rotInput = document.getElementById('layer-rotation') as HTMLInputElement;
    if (rotInput) rotInput.value = (active.rotation ?? 0).toString();
    
    const blendSelect = document.getElementById('layer-blend') as HTMLSelectElement;
    blendSelect.value = active.blendMode;

    const lx = document.getElementById('layer-x') as HTMLInputElement;
    const ly = document.getElementById('layer-y') as HTMLInputElement;
    const lw = document.getElementById('layer-w') as HTMLInputElement;
    const lh = document.getElementById('layer-h') as HTMLInputElement;

    // Toggle numeric bound fields based on layers type
    if (active.type === 'background' || active.type === 'overlay') {
      lx.closest('div')?.classList.add('hidden');
    } else {
      lx.closest('div')?.classList.remove('hidden');
      lx.value = (eff.x ?? 0).toString();
      ly.value = (eff.y ?? 0).toString();
      lw.value = (eff.width ?? 0).toString();
      lh.value = (eff.height ?? 0).toString();
    }

    // Toggle sub-panels based on layer type
    const pBg = document.getElementById('pane-bg') as HTMLDivElement;
    const pText = document.getElementById('pane-text') as HTMLDivElement;
    const pImage = document.getElementById('pane-image') as HTMLDivElement;
    const pShape = document.getElementById('pane-shape') as HTMLDivElement;
    const pOverlay = document.getElementById('pane-overlay') as HTMLDivElement;

    pBg.classList.add('hidden');
    pText.classList.add('hidden');
    pImage.classList.add('hidden');
    pShape.classList.add('hidden');
    pOverlay.classList.add('hidden');

    if (active.type === 'background') {
      pBg.classList.remove('hidden');
      
      const typeSelect = document.getElementById('bg-fill-type') as HTMLSelectElement;
      typeSelect.value = active.bgType || 'solid';
      
      // Hide/Show sub options
      document.getElementById('bg-solid-opt')?.classList.add('hidden');
      document.getElementById('bg-gradient-opt')?.classList.add('hidden');
      document.getElementById('bg-image-opt')?.classList.add('hidden');
      
      if (active.bgType === 'solid') {
        document.getElementById('bg-solid-opt')?.classList.remove('hidden');
        (document.getElementById('bg-color-picker') as HTMLInputElement).value = active.color || '#000000';
        (document.getElementById('bg-color-hex') as HTMLInputElement).value = active.color || '#000000';
      } else if (active.bgType === 'gradient') {
        document.getElementById('bg-gradient-opt')?.classList.remove('hidden');
        (document.getElementById('bg-grad-1') as HTMLInputElement).value = active.gradColor1 || '#ffffff';
        (document.getElementById('bg-grad-2') as HTMLInputElement).value = active.gradColor2 || '#000000';
        (document.getElementById('bg-grad-angle') as HTMLInputElement).value = (active.gradAngle ?? 90).toString();
      } else if (active.bgType === 'image') {
        document.getElementById('bg-image-opt')?.classList.remove('hidden');
        (document.getElementById('bg-image-size') as HTMLSelectElement).value = active.size || 'stretch';
      }
    } else if (active.type === 'text') {
      pText.classList.remove('hidden');
      
      (document.getElementById('text-content') as HTMLTextAreaElement).value = eff.text || '';
      (document.getElementById('text-font') as HTMLSelectElement).value = eff.fontFamily || 'Geist Mono';
      (document.getElementById('text-size') as HTMLInputElement).value = (eff.fontSize || 8).toString();
      (document.getElementById('text-align') as HTMLSelectElement).value = eff.align || 'left';
      (document.getElementById('text-color') as HTMLInputElement).value = eff.color || '#ffffff';
      
      const bBtn = document.getElementById('text-bold') as HTMLButtonElement;
      const iBtn = document.getElementById('text-italic') as HTMLButtonElement;
      const uBtn = document.getElementById('text-underline') as HTMLButtonElement;
      
      if (eff.bold) bBtn.classList.add('bg-neutral-850', 'text-white');
      else bBtn.classList.remove('bg-neutral-850', 'text-white');
      
      if (eff.italic) iBtn.classList.add('bg-neutral-850', 'text-white');
      else iBtn.classList.remove('bg-neutral-850', 'text-white');

      if (eff.underline) uBtn.classList.add('bg-neutral-850', 'text-white');
      else uBtn.classList.remove('bg-neutral-850', 'text-white');

      (document.getElementById('text-letter-spacing') as HTMLInputElement).value = (eff.letterSpacing ?? 0).toString();
      (document.getElementById('text-line-height') as HTMLInputElement).value = (eff.lineHeight ?? 1.2).toString();
      
      (document.getElementById('text-stroke-color') as HTMLInputElement).value = eff.strokeColor || '#000000';
      (document.getElementById('text-stroke-width') as HTMLInputElement).value = (eff.strokeWidth ?? 0).toString();
      (document.getElementById('text-shadow-color') as HTMLInputElement).value = eff.shadowColor || '#000000';
      (document.getElementById('text-shadow-blur') as HTMLInputElement).value = (eff.shadowBlur ?? 0).toString();
      (document.getElementById('text-shadow-x') as HTMLInputElement).value = (eff.shadowX ?? 0).toString();
      (document.getElementById('text-shadow-y') as HTMLInputElement).value = (eff.shadowY ?? 0).toString();

      // Glow Effect Options
      const glowEnable = document.getElementById('text-glow-enable') as HTMLInputElement;
      glowEnable.checked = !!eff.glowEnabled;
      const glowOpts = document.getElementById('text-glow-opts') as HTMLDivElement;
      if (eff.glowEnabled) {
        glowOpts.classList.remove('hidden');
        (document.getElementById('text-glow-color') as HTMLInputElement).value = eff.glowColor || '#ffffff';
        (document.getElementById('text-glow-size') as HTMLInputElement).value = (eff.glowSize ?? 4).toString();
      } else {
        glowOpts.classList.add('hidden');
      }
    } else if (active.type === 'image') {
      pImage.classList.remove('hidden');
      (document.getElementById('image-aspect-lock') as HTMLInputElement).checked = !!active.aspectLock;
      (document.getElementById('image-pixelated') as HTMLInputElement).checked = !!active.pixelated;

      // Crop Options
      const cropEnable = document.getElementById('image-crop-enable') as HTMLInputElement;
      cropEnable.checked = !!active.cropEnabled;
      const cropOpts = document.getElementById('image-crop-opts') as HTMLDivElement;
      if (active.cropEnabled) {
        cropOpts.classList.remove('hidden');
        (document.getElementById('image-crop-left') as HTMLInputElement).value = (active.cropLeft ?? 0).toString();
        (document.getElementById('image-crop-right') as HTMLInputElement).value = (active.cropRight ?? 0).toString();
        (document.getElementById('image-crop-top') as HTMLInputElement).value = (active.cropTop ?? 0).toString();
        (document.getElementById('image-crop-bottom') as HTMLInputElement).value = (active.cropBottom ?? 0).toString();
      } else {
        cropOpts.classList.add('hidden');
      }

      // Filter Options
      (document.getElementById('img-filter-grayscale') as HTMLInputElement).value = (active.filterGrayscale ?? 0).toString();
      (document.getElementById('img-filter-sepia') as HTMLInputElement).value = (active.filterSepia ?? 0).toString();
      (document.getElementById('img-filter-invert') as HTMLInputElement).value = (active.filterInvert ?? 0).toString();
      (document.getElementById('img-filter-blur') as HTMLInputElement).value = (active.filterBlur ?? 0).toString();
      (document.getElementById('img-filter-hue') as HTMLInputElement).value = (active.filterHueRotate ?? 0).toString();
      (document.getElementById('img-filter-contrast') as HTMLInputElement).value = (active.filterContrast ?? 100).toString();
      (document.getElementById('img-filter-bright') as HTMLInputElement).value = (active.filterBrightness ?? 100).toString();
    } else if (active.type === 'shape') {
      pShape.classList.remove('hidden');
      
      const st = eff.shapeType || 'rect';
      (document.getElementById('shape-type') as HTMLSelectElement).value = st;
      (document.getElementById('shape-fill-enable') as HTMLInputElement).checked = !!eff.fillEnabled;
      (document.getElementById('shape-fill-color') as HTMLInputElement).value = eff.fillColor || '#ffffff';
      (document.getElementById('shape-border-color') as HTMLInputElement).value = eff.borderColor || '#000000';
      (document.getElementById('shape-border-width') as HTMLInputElement).value = (eff.borderWidth ?? 0).toString();
      
      if (eff.fillEnabled && eff.shapeType !== 'line') {
        document.getElementById('shape-fill-color-row')?.classList.remove('hidden');
      } else {
        document.getElementById('shape-fill-color-row')?.classList.add('hidden');
      }

      // Show/Hide shape parameters
      const radRow = document.getElementById('shape-radius-row') as HTMLDivElement;
      const sidesRow = document.getElementById('shape-sides-row') as HTMLDivElement;
      const starRow = document.getElementById('shape-star-row') as HTMLDivElement;

      radRow.classList.add('hidden');
      sidesRow.classList.add('hidden');
      starRow.classList.add('hidden');

      if (st === 'roundrect') {
        radRow.classList.remove('hidden');
        (document.getElementById('shape-border-radius') as HTMLInputElement).value = (eff.borderRadius ?? 4).toString();
      } else if (st === 'polygon') {
        sidesRow.classList.remove('hidden');
        (document.getElementById('shape-polygon-sides') as HTMLInputElement).value = (eff.polygonSides ?? 5).toString();
      } else if (st === 'star') {
        starRow.classList.remove('hidden');
        (document.getElementById('shape-star-points') as HTMLInputElement).value = (eff.starPoints ?? 5).toString();
        (document.getElementById('shape-star-inner') as HTMLInputElement).value = (eff.starInnerRatio ?? 0.4).toString();
      }
    } else if (active.type === 'overlay') {
      pOverlay.classList.remove('hidden');
      (document.getElementById('overlay-style') as HTMLSelectElement).value = active.overlayType || 'scanlines';
    }
  }

