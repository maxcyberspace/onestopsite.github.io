    { name: 'GitHub', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16"><rect width="16" height="16" rx="2" fill="#181717"/><path d="M8 2 C4.7 2 2 4.7 2 8 c0 2.6 1.7 4.9 4 5.7 c.3 .1 .4 -.1 .4 -.3 c0 -.2 0 -.7 0-1.4 c-1.7 .4-2-1-2-1 c-.3 -.7-.7-.9-.7-.9 c-.5 -.4 0 -.4 0 -.4 c.6 0 .9 .6 .9 .6 c.5 .9 1.4 .6 1.7 .5 c0 -.4 .2 -.7 .4 -.8 c-1.3 -.1-2.7 -.7-2.7-3 c0 -.6 .2-1.2 .6-1.6 c-.1 -.1 -.3 -.7 0-1.6 c0 0 .5 -.2 1.6 .6 C6.7 4.6 7.3 4.5 8 4.5 c.7 0 1.3 .1 1.8 .3 c1.1 -.8 1.6 -.6 1.6 -.6 c.3 .9 .1 1.5 0 1.6 c.4 .4 .6 1 .6 1.6 c0 2.3 -1.4 2.8 -2.7 3 c.2 .2 .4 .6 .4 1.2 c0 .8 0 1.5 0 1.7 c0 .2 .1 .4 .4 .3 C12.3 12.9 14 10.6 14 8 C14 5.3 11.3 2 8 2 Z" fill="#ffffff"/></svg>` },
    { name: 'Email', svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="16" height="16"><rect width="16" height="16" rx="2" fill="#2563eb" opacity="0.2"/><path d="M2 4 h12 v8 h-12 z" fill="#000000"/><path d="M3 5 h10 v6 h-10 z" fill="#ffffff"/><path d="M3 5 l5 3.5 l5 -3.5" fill="none" stroke="#d4d4d4" stroke-width="1"/><path d="M3 11 l3.5 -3" fill="none" stroke="#d4d4d4" stroke-width="1"/><path d="M13 11 l-3.5 -3" fill="none" stroke="#d4d4d4" stroke-width="1"/></svg>` }
  ];

  function renderAssetsGrid() {
    const assetsGrid = document.getElementById('assets-grid') as HTMLDivElement;
    if (!assetsGrid) return;
    assetsGrid.innerHTML = '';
    BUILTIN_ASSETS.forEach(asset => {
      const item = document.createElement('button');
      item.className = 'flex flex-col items-center justify-center rounded border border-neutral-900 hover:border-neutral-700 bg-black/40 hover:bg-neutral-900 p-2 text-[10px] text-neutral-400 hover:text-white transition-colors cursor-pointer select-none';
      item.setAttribute('data-tooltip', `Insert ${asset.name} icon asset`);
      
      const dataUrl = 'data:image/svg+xml;utf8,' + encodeURIComponent(asset.svg);
      
      item.innerHTML = `
        <img src="${dataUrl}" class="w-8 h-8 mb-1.5" style="image-rendering: pixelated;" alt="${asset.name}" />
        <span class="font-mono text-[9px]">${asset.name}</span>
      `;
      
      item.onclick = () => {
        addBuiltInAsset(asset.name, asset.svg);
      };
      
      assetsGrid.appendChild(item);
    });
  }

  function addBuiltInAsset(assetName: string, svgString: string) {
    const dataUrl = 'data:image/svg+xml;utf8,' + encodeURIComponent(svgString);
    preloadImage(dataUrl, (img) => {
      const id = `layer-${Date.now()}`;
      const newLayer: Layer = {
        id,
        name: assetName,
        type: 'image',
        visible: true,
        opacity: 100,
        blendMode: 'source-over',
        x: 36,
        y: 8,
        width: 16,
        height: 16,
        imageSrc: dataUrl,
        pixelated: true,
        aspectLock: true
      };
      project.layers.push(newLayer);
      project.activeLayerId = id;
      project.selectedLayerIds = [id];
      pushState();
      renderAll();
    });
  }

  // Position context menu
  function showContextMenu(clientX: number, clientY: number) {
    const contextMenu = document.getElementById('custom-context-menu') as HTMLDivElement;
    if (!contextMenu) return;
    
    const hasSelection = !!project.activeLayerId;
    const ctxLayerActions = document.getElementById('ctx-layer-actions') as HTMLDivElement;
    if (ctxLayerActions) {
      if (hasSelection) {
        ctxLayerActions.classList.remove('hidden');
      } else {
        ctxLayerActions.classList.add('hidden');
      }
    }
    
    contextMenu.classList.remove('hidden');
    
    const menuWidth = contextMenu.offsetWidth || 176;
    const menuHeight = contextMenu.offsetHeight || 250;
    
    let x = clientX;
    let y = clientY;
    
    if (x + menuWidth > window.innerWidth) {
      x = window.innerWidth - menuWidth - 4;
    }
    if (y + menuHeight > window.innerHeight) {
      y = window.innerHeight - menuHeight - 4;
    }
    
    contextMenu.style.left = `${Math.round(x)}px`;
    contextMenu.style.top = `${Math.round(y)}px`;
  }

  // Helper functions for layer ordering
  function bringToFront() {
    const ids = project.selectedLayerIds && project.selectedLayerIds.length > 0
      ? [...project.selectedLayerIds]
      : (project.activeLayerId ? [project.activeLayerId] : []);
    if (ids.length === 0) return;
    
    const selected = project.layers.filter(l => ids.includes(l.id));
    const nonSelected = project.layers.filter(l => !ids.includes(l.id));
    
    project.layers = [...nonSelected, ...selected];
    pushState();
    renderAll();
  }

  function sendToBack() {
    const ids = project.selectedLayerIds && project.selectedLayerIds.length > 0
      ? [...project.selectedLayerIds]
      : (project.activeLayerId ? [project.activeLayerId] : []);
    if (ids.length === 0) return;
    
    const selected = project.layers.filter(l => ids.includes(l.id));
    const nonSelected = project.layers.filter(l => !ids.includes(l.id));
    
    let bgIndex = 0;
    if (nonSelected.length > 0 && nonSelected[0].type === 'background') {
      bgIndex = 1;
    }
    
    const firstPart = nonSelected.slice(0, bgIndex);
    const secondPart = nonSelected.slice(bgIndex);
    
    project.layers = [...firstPart, ...selected, ...secondPart];
    pushState();
    renderAll();
  }

  function setupContextMenuAndTooltips() {
    const contextMenu = document.getElementById('custom-context-menu') as HTMLDivElement;
    const canvasWorkspace = document.getElementById('canvas-workspace-wrapper');
    
    if (contextMenu && canvasWorkspace) {
      // Hide context menu on normal click
      window.addEventListener('click', () => {
        contextMenu.classList.add('hidden');
      });
      window.addEventListener('blur', () => {
        contextMenu.classList.add('hidden');
      });
      
      // Right click on canvas workspace
      canvasWorkspace.addEventListener('contextmenu', (e) => {
        e.preventDefault();
        
        const rect = canvas.getBoundingClientRect();
        const scale = project.zoom / 100;
        const mouseX = (e.clientX - rect.left) / scale;
        const mouseY = (e.clientY - rect.top) / scale;
        
        const clickedLayer = findLayerAt(mouseX, mouseY);
        if (clickedLayer) {
          project.selectedLayerIds = [clickedLayer.id];
          project.activeLayerId = clickedLayer.id;
          renderAll();
        } else {
          project.selectedLayerIds = [];
          project.activeLayerId = null;
          renderAll();
        }
        
        showContextMenu(e.clientX, e.clientY);
      });
      
      // Wire context menu buttons
      const ctxDup = document.getElementById('ctx-duplicate');
      if (ctxDup) ctxDup.onclick = () => duplicateActiveLayer();
      
      const ctxDel = document.getElementById('ctx-delete');
      if (ctxDel) ctxDel.onclick = () => deleteActiveLayer();
      
      const ctxVis = document.getElementById('ctx-toggle-visibility');
      if (ctxVis) {
        ctxVis.onclick = () => {
          if (project.activeLayerId) {
            const active = project.layers.find(l => l.id === project.activeLayerId);
            if (active) {
              active.visible = !active.visible;
              pushState();
              renderAll();
            }
          }
        };
      }
      
      const ctxFront = document.getElementById('ctx-bring-front');
      if (ctxFront) ctxFront.onclick = () => bringToFront();
      
      const ctxBack = document.getElementById('ctx-send-back');
      if (ctxBack) ctxBack.onclick = () => sendToBack();
      
      const ctxAddText = document.getElementById('ctx-add-text');
      if (ctxAddText) ctxAddText.onclick = () => addLayer('text');
      
      const ctxAddImg = document.getElementById('ctx-add-image');
      if (ctxAddImg) ctxAddImg.onclick = () => addLayer('image');
      
      const ctxAddShape = document.getElementById('ctx-add-shape');
      if (ctxAddShape) ctxAddShape.onclick = () => addLayer('shape');
      
      const ctxAddOverlay = document.getElementById('ctx-add-overlay');
      if (ctxAddOverlay) ctxAddOverlay.onclick = () => addLayer('overlay');
    }
    
    // Tooltip handler
    const tooltip = document.getElementById('custom-tooltip');
    if (tooltip) {
      document.addEventListener('mouseover', (e) => {
        const target = e.target as HTMLElement;
        const el = target.closest('[data-tooltip]');
        if (!el) {
          tooltip.classList.remove('opacity-100');
          tooltip.classList.add('opacity-0');
          return;
        }
        const text = el.getAttribute('data-tooltip');
        if (!text) return;
        tooltip.textContent = text;
        
        tooltip.classList.remove('opacity-0');
        tooltip.classList.add('opacity-100');
        
        const rect = el.getBoundingClientRect();
        const tooltipRect = tooltip.getBoundingClientRect();
        let left = rect.left + (rect.width - tooltipRect.width) / 2;
        let top = rect.top - tooltipRect.height - 6;
        
        if (left < 4) left = 4;
        if (left + tooltipRect.width > window.innerWidth - 4) {
          left = window.innerWidth - tooltipRect.width - 4;
        }
        if (top < 4) {
          top = rect.bottom + 6;
        }
        
        tooltip.style.left = `${Math.round(left)}px`;
        tooltip.style.top = `${Math.round(top)}px`;
      });
      
      document.addEventListener('mouseout', (e) => {
        const target = e.target as HTMLElement;
        const el = target.closest('[data-tooltip]');
        if (el) {
          tooltip.classList.remove('opacity-100');
          tooltip.classList.add('opacity-0');
        }
      });
    }
  }

  // Main UI Initialization
  function init() {
    // 1. Setup default templates if param preset matches
    const params = new URLSearchParams(window.location.search);
    const presetParam = params.get('preset');
    
    // Check if we have autosave cache
    const cached = localStorage.getItem('onestopsite-active-project');
    
    if (presetParam && PRESETS[presetParam]) {
      loadPreset(presetParam);
    } else if (cached) {
      try {
        const restored = JSON.parse(cached);
        project.name = restored.name;
        project.layers = restored.layers;
        project.frames = restored.frames;
        project.activeLayerId = project.layers[project.layers.length - 1]?.id || null;
        project.activeFrameIndex = 0;
        
        const nameInput = document.getElementById('project-name') as HTMLInputElement;
        if (nameInput) nameInput.value = project.name;
        
        preloadProjectImages(() => {
          renderAll();
        });
        
        // Save initial stack
        pushState();
      } catch (e) {
        loadPreset('win95'); // default fallback
      }
    } else {
      loadPreset('win95');
    }

    // 2. Bind listeners
    bindInspectorInputs();
    setupDraggingListeners();
    setupGlobalHotkeys();
    setupContextMenuAndTooltips();

    // Toggle grid styling by default (handled dynamically in renderCanvas)
    canvas.style.backgroundImage = 'none';

    // Dropdown toggles
    addLayerBtn.onclick = (e) => {
      e.stopPropagation();
      addLayerMenu.classList.toggle('hidden');
      exportMenu.classList.add('hidden');
    };
    
    exportBtn.onclick = (e) => {
      e.stopPropagation();
      exportMenu.classList.toggle('hidden');
      addLayerMenu.classList.add('hidden');
    };

    window.onclick = () => {
      addLayerMenu.classList.add('hidden');
      exportMenu.classList.add('hidden');
    };

    // Layer selection trigger items
    document.querySelectorAll('.add-layer-opt').forEach(opt => {
      (opt as HTMLButtonElement).onclick = () => {
        const type = (opt as HTMLButtonElement).dataset.type as any;
        addLayer(type);
      };
    });

    // Delete Active Layer Click
    btnDeleteActiveLayer.onclick = () => deleteActiveLayer();

    // Duplicate Active Layer Click
    btnDuplicateActiveLayer.onclick = () => duplicateActiveLayer();

    // Export selectors trigger options
    document.querySelectorAll('.export-opt').forEach(opt => {
      (opt as HTMLButtonElement).onclick = () => {
        const fmt = (opt as HTMLButtonElement).dataset.format;
        if (fmt === 'png1x') exportPNG(1);
        if (fmt === 'png2x') exportPNG(2);
        if (fmt === 'png4x') exportPNG(4);
      };
    });

    // GIF exports
    const exportGifBtn = document.getElementById('export-gif-btn') as HTMLButtonElement;
    exportGifBtn.onclick = () => exportGIF(1);
    
    const exportGifBtnLarge = document.getElementById('export-gif-btn-large') as HTMLButtonElement;
    exportGifBtnLarge.onclick = () => exportGIF(4);

    // Preset options selection trigger
    const presetSelect = document.getElementById('select-preset') as HTMLSelectElement;
    presetSelect.onchange = () => {
      const val = presetSelect.value;
      if (val) {
        loadPreset(val);
        presetSelect.value = ''; // Reset dropdown selection
      }
    };

    // Playback timeline
    playPauseBtn.onclick = () => {
      if (project.isPlaying) pausePlayback();
      else startPlayback();
    };

    speedSelect.onchange = () => {
      if (project.isPlaying) {
        pausePlayback();
        startPlayback();
      }
    };

    // Add frame timeline click
    addFrameBtn.onclick = () => {
      const lastFrame = project.frames[project.frames.length - 1];
      const newFrame = {
        id: `frame-${Date.now()}`,
        delay: lastFrame ? lastFrame.delay : 200,
        overrides: lastFrame ? JSON.parse(JSON.stringify(lastFrame.overrides)) : {}
      };
      project.frames.push(newFrame);
      project.activeFrameIndex = project.frames.length - 1;
      pushState();
      renderAll();
    };

    // Image Upload triggers
    const bgImgInput = document.getElementById('bg-image-file') as HTMLInputElement;
    bgImgInput.onchange = (e) => handleImageUpload(e, 'bg');
    
    const layerImgInput = document.getElementById('image-layer-file') as HTMLInputElement;
    layerImgInput.onchange = (e) => handleImageUpload(e, 'layer');

    // JSON Project Imports
    const jsonImportTrigger = document.getElementById('btn-import-json-trigger') as HTMLButtonElement;
    const jsonImportInput = document.getElementById('input-import-json') as HTMLInputElement;
    
    jsonImportTrigger.onclick = () => jsonImportInput.click();
    jsonImportInput.onchange = () => {
      if (!jsonImportInput.files || jsonImportInput.files.length === 0) return;
      const file = jsonImportInput.files[0];
      const reader = new FileReader();
      reader.onload = (evt) => {
        try {
          const content = evt.target?.result as string;
          const parsed = JSON.parse(content);
          if (parsed.layers && parsed.frames) {
            project.name = parsed.name || "Imported Project";
            project.layers = parsed.layers;
            project.frames = parsed.frames;
            project.activeLayerId = project.layers[project.layers.length - 1]?.id || null;
            project.activeFrameIndex = 0;
            
            const nameInput = document.getElementById('project-name') as HTMLInputElement;
            if (nameInput) nameInput.value = project.name;
            
            pushState();
            preloadProjectImages(() => {
              renderAll();
            });
            alert('Project Loaded Successfully!');
          }
        } catch (e) {
          alert('Invalid JSON project structure file.');
        }
      };
      reader.readAsText(file);
    };

    // JSON Project Exports
    const jsonExportBtn = document.getElementById('btn-export-json') as HTMLButtonElement;
    jsonExportBtn.onclick = () => {
      const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(project, null, 2));
      const downloadAnchor = document.createElement('a');
      downloadAnchor.setAttribute("href",     dataStr);
      downloadAnchor.setAttribute("download", `${project.name.replace(/\s+/g, '-').toLowerCase()}.json`);
      document.body.appendChild(downloadAnchor);
      downloadAnchor.click();
      downloadAnchor.remove();
    };

    // Undo/Redo Header triggers
    const undoBtn = document.getElementById('btn-undo') as HTMLButtonElement;
    undoBtn.onclick = () => undo();
    
    const redoBtn = document.getElementById('btn-redo') as HTMLButtonElement;
    redoBtn.onclick = () => redo();

    // Tab switching logic for Left Panel
    const tabBtnLayers = document.getElementById('tab-btn-layers') as HTMLButtonElement;
    const tabBtnAssets = document.getElementById('tab-btn-assets') as HTMLButtonElement;
    const tabContentLayers = document.getElementById('tab-content-layers') as HTMLDivElement;
    const tabContentAssets = document.getElementById('tab-content-assets') as HTMLDivElement;

    if (tabBtnLayers && tabBtnAssets && tabContentLayers && tabContentAssets) {
      tabBtnLayers.onclick = () => {
        tabBtnLayers.classList.add('border-b-emerald-500', 'text-white', 'bg-black/30');
        tabBtnLayers.classList.remove('border-b-transparent');
        
        tabBtnAssets.classList.remove('border-b-emerald-500', 'text-white', 'bg-black/30');
        tabBtnAssets.classList.add('border-b-transparent');
        
        tabContentLayers.classList.remove('hidden');
        tabContentAssets.classList.add('hidden');
      };

      tabBtnAssets.onclick = () => {
        tabBtnAssets.classList.add('border-b-emerald-500', 'text-white', 'bg-black/30');
        tabBtnAssets.classList.remove('border-b-transparent');
        
        tabBtnLayers.classList.remove('border-b-emerald-500', 'text-white', 'bg-black/30');
        tabBtnLayers.classList.add('border-b-transparent');
        
        tabContentAssets.classList.remove('hidden');
        tabContentLayers.classList.add('hidden');
        renderAssetsGrid();
      };
    }
  }

  // Run initial loading
  window.onload = () => {
    init();
  };
</script>
